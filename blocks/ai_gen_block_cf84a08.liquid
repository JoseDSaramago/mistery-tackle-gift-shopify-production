{% doc %}
  @prompt
    Create a clean legal terms and conditions page layout.
    
    Requirements:
    - Large centered heading at the top (Terms and Conditions)
    - Subheading below for Effective Date
    - Multiple sections with:
      - Numbered section titles (e.g. 1. Acceptance and Modifications)
      - Paragraph text under each section
    - Use a clean, minimal layout with good spacing
    - Left-align all body text
    - Make section titles bold and slightly larger than body text
    - Keep the design simple and readable (legal style)
    
    Style:
    - Professional, minimal, no decorative elements
    - Focus on readability and hierarchy
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-legal-terms-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.section_spacing }}px 20px;
    background-color: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
    font-family: {{ block.settings.body_font.family }}, sans-serif;
    line-height: 1.6;
  }

  .ai-legal-terms__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.section_spacing }}px;
    padding-bottom: {{ block.settings.section_spacing | divided_by: 2 }}px;
    border-bottom: 1px solid {{ block.settings.divider_color }};
  }

  .ai-legal-terms__title-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, sans-serif;
    font-size: {{ block.settings.title_size }}px;
    font-weight: 700;
    margin: 0 0 {{ block.settings.section_spacing | divided_by: 2 }}px 0;
    color: {{ block.settings.heading_color }};
    line-height: 1.2;
  }

  .ai-legal-terms__effective-date-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0;
    font-style: italic;
  }

  .ai-legal-terms__content-{{ ai_gen_id }} {
    max-width: {{ block.settings.content_max_width }}px;
    margin: 0 auto;
  }

  .ai-legal-terms__section-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.section_spacing }}px;
  }

  .ai-legal-terms__section-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, sans-serif;
    font-size: {{ block.settings.section_title_size }}px;
    font-weight: 700;
    margin: 0 0 {{ block.settings.paragraph_spacing }}px 0;
    color: {{ block.settings.heading_color }};
    line-height: 1.3;
  }

  .ai-legal-terms__section-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.body_size }}px;
    margin: 0 0 {{ block.settings.paragraph_spacing }}px 0;
    color: {{ block.settings.text_color }};
  }

  .ai-legal-terms__section-text-{{ ai_gen_id }}:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-legal-terms-{{ ai_gen_id }} {
      width: 100%;
      padding: {{ block.settings.section_spacing | times: 0.7 }}px 16px;
    }

    .ai-legal-terms__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.7 }}px;
    }

    .ai-legal-terms__effective-date-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.85 }}px;
    }

    .ai-legal-terms__section-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.section_title_size | times: 0.85 }}px;
    }

    .ai-legal-terms__body-{{ ai_gen_id }} {
      font-size: {{ block.settings.body_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-legal-terms-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-legal-terms__header-{{ ai_gen_id }}">
    {% if block.settings.page_title != blank %}
      <h1 class="ai-legal-terms__title-{{ ai_gen_id }}">{{ block.settings.page_title }}</h1>
    {% endif %}
    {% if block.settings.effective_date != blank %}
      <p class="ai-legal-terms__effective-date-{{ ai_gen_id }}">{{ block.settings.effective_date }}</p>
    {% endif %}
  </div>

  <div class="ai-legal-terms__content-{{ ai_gen_id }}">
    {% for i in (1..10) %}
      {% liquid
        assign section_enabled_key = 'section_' | append: i | append: '_enabled'
        assign section_title_key = 'section_' | append: i | append: '_title'
        assign section_text_key = 'section_' | append: i | append: '_text'

        assign section_enabled = block.settings[section_enabled_key]
        assign section_title = block.settings[section_title_key]
        assign section_text = block.settings[section_text_key]
      %}

      {% if section_enabled and section_title != blank %}
        <div class="ai-legal-terms__section-{{ ai_gen_id }}">
          <h2 class="ai-legal-terms__section-title-{{ ai_gen_id }}">{{ section_title }}</h2>
          {% if section_text != blank %}
            <div class="ai-legal-terms__section-text-{{ ai_gen_id }}">{{ section_text }}</div>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>

