{% doc %}
  @prompt
    Create a Shopify section named "Portal Promo Banner (Container)".
    
    LAYOUT:
    
    * The section MUST be inside a centered container (max-width: 1200px).
    * Content should be horizontally centered with margin: 0 auto and padding: 0 20px.
    * Do NOT use full-width / edge-to-edge layout.
    
    STRUCTURE:
    
    * Single promotional banner section.
    * Desktop: show a wide horizontal banner image.
    * Mobile: show a separate optimized mobile image.
    * Only ONE image visible at a time (responsive behavior).
    
    RESPONSIVE BEHAVIOR:
    
    * Desktop (≥768px): show desktop image, hide mobile image.
    * Mobile (<768px): show mobile image, hide desktop image.
    
    IMAGE SETTINGS:
    
    * Add two image pickers:
    
      1. Desktop image
      2. Mobile image
    * Images should scale to container width (width: 100%, height: auto).
    * Optional setting: make entire banner clickable (URL field).
    
    STYLING:
    
    * No borders, no shadows, no card/boxed UI.
    * Background should be configurable via a section setting (default: #F9F4ED).
    * Keep spacing tight and clean (top/bottom padding: 16–24px max).
    
    BRAND ALIGNMENT:
    
    * Clean, minimal, outdoors/fishing brand feel.
    * No heavy styling — let the image carry the design.
    
    ADVANCED:
    
    * Ensure the section does NOT exceed 1200px width at any screen size.
    * Ensure proper spacing from other sections (no overlap).
    * Optimize for fast loading (no unnecessary wrappers).
    
    PORTAL-ONLY VISIBILITY (CRITICAL):
    
    * Wrap the ENTIRE section output in a Liquid condition so it ONLY renders when:
    
      * The page is part of the Recharge portal
      * AND the page is NOT the login/access page
    * The logic should:
    
      * Include pages where request.path contains "/tools/recurring" or "/portal/"
      * Exclude the login page at "/tools/recurring/get-subscription-access"
    * Keep the condition simple and stable (avoid complex nesting or syntax that may break section rendering).
    * The visibility condition must be the first line of the section and closed at the very end.
    
    OUTPUT:
    
    * Fully editable section with settings for:
    
      * Desktop image
      * Mobile image
      * Link URL
      * Background color
      * Spacing
    * Must be compatible with Shopify OS 2.0 and editable in Theme Editor.
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}
{% assign is_portal_page = false %}
{% if request.path contains '/tools/recurring' or request.path contains '/portal/' %}
  {% unless request.path contains '/tools/recurring/get-subscription-access' %}
    {% assign is_portal_page = true %}
  {% endunless %}
{% endif %}

{% if is_portal_page %}
  {% style %}
    .ai-portal-promo-banner-{{ ai_gen_id }} {
      background-color: {{ block.settings.background_color }};
      padding: {{ block.settings.spacing_top }}px 20px {{ block.settings.spacing_bottom }}px;
      display: block;
    }

    .ai-portal-promo-banner-container-{{ ai_gen_id }} {
      max-width: 1200px;
      margin: 0 auto;
      width: 100%;
    }

    .ai-portal-promo-banner-link-{{ ai_gen_id }} {
      display: block;
      text-decoration: none;
    }

    .ai-portal-promo-banner-image-{{ ai_gen_id }} {
      width: 100%;
      height: auto;
      display: block;
    }

    .ai-portal-promo-banner-desktop-{{ ai_gen_id }} {
      display: none;
    }

    .ai-portal-promo-banner-mobile-{{ ai_gen_id }} {
      display: block;
    }

    .ai-portal-promo-banner-placeholder-{{ ai_gen_id }} {
      background-color: #f4f4f4;
      width: 100%;
      min-height: 200px;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
    }

    .ai-portal-promo-banner-placeholder-{{ ai_gen_id }} svg {
      width: 100%;
      height: 100%;
      max-width: 500px;
      max-height: 300px;
    }

    .ai-portal-promo-banner-empty-state-{{ ai_gen_id }} {
      position: absolute;
      bottom: 20px;
      left: 50%;
      transform: translateX(-50%);
      padding: 12px 20px;
      font-size: 14px;
      color: #666;
      text-align: center;
      pointer-events: none;
    }

    @media screen and (min-width: 768px) {
      .ai-portal-promo-banner-desktop-{{ ai_gen_id }} {
        display: block;
      }

      .ai-portal-promo-banner-mobile-{{ ai_gen_id }} {
        display: none;
      }
    }
  {% endstyle %}

  <portal-promo-banner-{{ ai_gen_id }}
    class="ai-portal-promo-banner-{{ ai_gen_id }}"
    {{ block.shopify_attributes }}
  >
    <div class="ai-portal-promo-banner-container-{{ ai_gen_id }}">
      {% if block.settings.banner_link != blank %}
        <a
          href="{{ block.settings.banner_link }}"
          class="ai-portal-promo-banner-link-{{ ai_gen_id }}"
        >
          {% if block.settings.desktop_image %}
            <img
              src="{{ block.settings.desktop_image | image_url: width: 1200 }}"
              alt="{{ block.settings.desktop_image.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.desktop_image.width }}"
              height="{{ block.settings.desktop_image.height }}"
              class="ai-portal-promo-banner-image-{{ ai_gen_id }} ai-portal-promo-banner-desktop-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-portal-promo-banner-placeholder-{{ ai_gen_id }} ai-portal-promo-banner-desktop-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
              <div class="ai-portal-promo-banner-empty-state-{{ ai_gen_id }}">
                Add a desktop banner image
              </div>
            </div>
          {% endif %}

          {% if block.settings.mobile_image %}
            <img
              src="{{ block.settings.mobile_image | image_url: width: 800 }}"
              alt="{{ block.settings.mobile_image.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.mobile_image.width }}"
              height="{{ block.settings.mobile_image.height }}"
              class="ai-portal-promo-banner-image-{{ ai_gen_id }} ai-portal-promo-banner-mobile-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-portal-promo-banner-placeholder-{{ ai_gen_id }} ai-portal-promo-banner-mobile-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
              <div class="ai-portal-promo-banner-empty-state-{{ ai_gen_id }}">
                Add a mobile banner image
              </div>
            </div>
          {% endif %}
        </a>
      {% else %}
        {% if block.settings.desktop_image %}
          <img
            src="{{ block.settings.desktop_image | image_url: width: 1200 }}"
            alt="{{ block.settings.desktop_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.desktop_image.width }}"
            height="{{ block.settings.desktop_image.height }}"
            class="ai-portal-promo-banner-image-{{ ai_gen_id }} ai-portal-promo-banner-desktop-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-portal-promo-banner-placeholder-{{ ai_gen_id }} ai-portal-promo-banner-desktop-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-portal-promo-banner-empty-state-{{ ai_gen_id }}">
              Add a desktop banner image
            </div>
          </div>
        {% endif %}

        {% if block.settings.mobile_image %}
          <img
            src="{{ block.settings.mobile_image | image_url: width: 800 }}"
            alt="{{ block.settings.mobile_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.mobile_image.width }}"
            height="{{ block.settings.mobile_image.height }}"
            class="ai-portal-promo-banner-image-{{ ai_gen_id }} ai-portal-promo-banner-mobile-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-portal-promo-banner-placeholder-{{ ai_gen_id }} ai-portal-promo-banner-mobile-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-portal-promo-banner-empty-state-{{ ai_gen_id }}">
              Add a mobile banner image
            </div>
          </div>
        {% endif %}
      {% endif %}
    </div>
  </portal-promo-banner-{{ ai_gen_id }}>

  <script>
    (function() {
      class PortalPromoBanner{{ ai_gen_id }} extends HTMLElement {
        constructor() {
          super();
        }
      }

      customElements.define('portal-promo-banner-{{ ai_gen_id }}', PortalPromoBanner{{ ai_gen_id }});
    })();
  </script>
{% endif %}

{% schema %}
{
  "name": "Portal promo banner",
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image"
    },
    {
      "type": "header",
      "content": "Link"
    },
    {
      "type": "url",
      "id": "banner_link",
      "label": "Banner link"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#F9F4ED"
    },
    {
      "type": "range",
      "id": "spacing_top",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Top spacing",
      "default": 16
    },
    {
      "type": "range",
      "id": "spacing_bottom",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Bottom spacing",
      "default": 16
    }
  ],
  "presets": [
    {
      "name": "Portal promo banner"
    }
  ]
}
{% endschema %}