{%- comment -%}
  Card de selección de box size para el configurador de gift plans.
  Parámetros:
    - product: objeto producto de Shopify
    - box_size: "regular" | "pro" | "elite"
{%- endcomment -%}

{%- if product != blank -%}
  {%- liquid
    assign label = product.metafields.custom.popularity_label
    assign items = product.metafields.custom.items_per_box
    assign value = product.metafields.custom.value_per_box
    assign box_title = box_size | capitalize | append: ' Box'
  -%}

  <label class="gift-plans__box-card" data-box-size="{{ box_size }}">
    <input
      type="radio"
      name="gift_box_size"
      value="{{ box_size }}"
      class="gift-plans__box-radio sr-only"
      aria-label="{{ box_title }}"
    >

    {%- if label != blank -%}
      <span class="gift-plans__box-badge">{{ label }}</span>
    {%- endif -%}

    <div class="gift-plans__box-image-wrap">
      {%- if product.featured_image != blank -%}
        <img
          src="{{ product.featured_image | image_url: width: 400 }}"
          alt="{{ product.title | escape }}"
          class="gift-plans__box-image"
          loading="lazy"
          width="400"
          height="400"
        >
      {%- endif -%}
    </div>

    <div class="gift-plans__box-info">
      <h3 class="gift-plans__box-title">{{ box_title }}</h3>

      {%- if items != blank -%}
        <span class="gift-plans__box-detail">{{ items }}</span>
      {%- endif -%}

      {%- if value != blank -%}
        <span class="gift-plans__box-detail">{{ value }}</span>
      {%- endif -%}
    </div>
  </label>
{%- endif -%}
