ct-position: center;position: absolute;height: 100%;width: 100%;left: 0px;top: 0px;" /> </picture> <div class="builder-image-sizer" style="width: 100%;padding-top: 100%;pointer-events: none;font-size: 0;"></div> </div> </div> </div>  </div> </div> </div> </div>  <div class="builder-block builder-4ab9731"> <div style="height: 100%;width: 100%;align-self: stretch;flex-grow: 1;box-sizing: border-box;max-width: 1200px;display: flex;flex-direction: column;align-items: stretch;margin-left: auto;margin-right: auto;"> </div> </div>  <div class="builder-block builder-ff89cea"> <div style="height: 100%;width: 100%;align-self: stretch;flex-grow: 1;box-sizing: border-box;max-width: 1200px;display: flex;flex-direction: column;align-items: stretch;margin-left: auto;margin-right: auto;">  <div class="builder-block builder-afa221a">  <div id="unitingwaters" class="builder-block builder-ea21492 ribbon">  <span class="builder-text"> <p>A SHORT FILM BY MTB:FC</p> </span> </div>  <div class="builder-block builder-5dd757e">  <span class="builder-text"> Watch: UNITING WATERS </span> </div>  <div class="builder-block builder-cd29468">  <span class="builder-text"> Join the original MTB:FC crew—Ryan, Hunter, and Ty— as they head south to fish Falcon Lake's historic waters, meet the locals, swap tackle, and share food and laughter that need no translation. </span> </div>  <div class="builder-block builder-978accd"> </div>  <div class="builder-block builder-dd13ddc ribbon">  <span class="builder-text"> <p>Zapata, TX</p> </span> </div>  <div class="builder-block builder-2b2b38a">  <div class="builder-block builder-f3d6b5c"> {%- assign _use_img_url = 'https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F2af2b0fafab24f1a9cc14141d1b03028?width=20' -%} <picture> <source srcset="https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F2af2b0fafab24f1a9cc14141d1b03028?format=webp&width=100 100w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88