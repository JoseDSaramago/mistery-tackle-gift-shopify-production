c39659bcab9%2F2af2b0fafab24f1a9cc14141d1b03028?format=webp&width=400 400w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F2af2b0fafab24f1a9cc14141d1b03028?format=webp&width=800 800w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F2af2b0fafab24f1a9cc14141d1b03028?format=webp&width=1200 1200w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F2af2b0fafab24f1a9cc14141d1b03028?format=webp&width=1600 1600w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F2af2b0fafab24f1a9cc14141d1b03028?format=webp&width=2000 2000w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F2af2b0fafab24f1a9cc14141d1b03028?width=20&format=webp 20w" type="image/webp" /> <img alt="" loading="lazy" src="{{ _use_img_url }}" sizes="(max-width: 638px) 4vw, (max-width: 998px) 3vw, 2vw" style="object-fit: contain;object-position: center;position: absolute;height: 100%;width: 100%;left: 0px;top: 0px;" /> </picture> <div class="builder-image-sizer" style="width: 100%;padding-top: 96.6%;pointer-events: none;font-size: 0;"></div> </div> </div>  <div class="builder-block builder-09fdf10">  <div class="builder-columns"> <div class="builder-column" style="line-height: normal;display: flex;flex-direction: column;align-items: stretch;" > <div class="builder-blocks" builder-type="blocks">  <div class="builder-block builder-aecdf90">  <span class="builder-text"> WHERE FISHING HAS NO BORDERS </span> </div>  <div class="builder-block builder-0376583">  <span class="builder-text"> <div>Falcon Lake sits on the Texas–Mexico border, where red-dirt roads meet blue water and the horizon hums with stories. Built in the 1950s by damming the Rio Grande, the lake swallowed old towns, churches, and roads—leaving a ghostly landscape that’s as mysterious as it is magnetic.</div><div><br></div><div>It’s legendary water for big bass, but it’s also a living crossroads of cultures. On any given day you’ll find Texas anglers working crankbaits through flooded brush while Mexican fishermen sling hand-lines from tin boats just a few hundred yards away. Different languages, same mission: chase the next strike.</div> </span> </div> </div> </div> <div class="builder-column" style="line-height: normal;display: flex;flex-direction: column;align-items: stretch;" > <div class="builder-blocks" builder-type="blocks">  <div class="builder-block builder-8a5b528"> {%- assign _use_img_url = 'https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F8b551d1e1b804cd5bbcbd861965e3eb0?width=534' -%} <picture> <source srcset="https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F8b551d1e1b804cd5bbcbd861965e3eb0?format=webp&width=100 100w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F8b551d1e1b804cd5bbcbd861965e3eb0?format=webp&width=200 200w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F8b551d1e1b804cd5bbcbd861965e3eb0?format=webp&width=400 400w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F8b551d1e1b804cd5bbcbd861965e3eb0?format=webp&width=800 800w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F8b551d1e1b804cd5bbcbd861965e3eb0?format=webp&width=1200 1200w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F8b551d1e1b804cd5bbcbd861965e3eb0?format=webp&width=1600 1600w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F8b551d1e1b804cd5bbcbd861965e3eb0?format=webp&width=2000 2000w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F8b551d1e1b804cd5bbcbd861965e3eb0?width=534&format=webp 534w" type="image/webp" /> <img alt="" loading="lazy" src="{{ _use_img_url }}" sizes="(max-width: 638px) 84vw, (max-width: 998px) 53vw, 38vw" style="object-fit: cover;object-position: center;position: absolute;height: 100%;width: 100%;left: 0px;top: 0px;" /> </picture> <div class="builder-image-sizer" style="width: 100%;padding-top: 56.39999999999999%;pointer-events: none;font-size: 0;"></div> </div> </div> </div>  </div> </div>  <div class="builder-block builder-e909857">  <div class="builder-columns"> <div class="builder-column" style="line-height: normal;display: flex;flex-direction: column;align-items: stretch;" > <div class="builder-blocks" builder-type="blocks">  <div class="builder-block builder-95d2c37"> {%- assign _use_img_url = 'https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F2e0541f9af764ec2811f5353bd317814?width=534' -%} <picture> <source srcset="https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F2e0541f9af764ec2811f5353bd317814?format=webp&width=100 100w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F2e0541f9af764ec2811f5353bd317814?format=webp&width=200 200w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F2e0541f9af764ec2811f5353bd317814?format=webp&width=400 400w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F2e0541f9af764ec2811f5353bd317814?format=webp&width=800 800w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F2e0541f9af764ec2811f5353bd317814?format=webp&width=1200 1200w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F2e0541f9af764ec2811f5353bd317814?format=webp&width=1600 1600w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F2e0541f9af764ec2811f5353bd317814?format=webp&width=2000 2000w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F2e0541f9af764ec2811f5353bd317814?width=534&format=webp 534w" type="image/webp" /> <img alt="" loading="lazy" src="{{ _use_img_url }}" sizes="(max-width: 638px) 84vw, (max-width: 998px) 47vw, 33vw" style="object-fit: cover;object-position: center;position: absolute;height: 100%;width: 100%;left: 0px;top: 0px;" /> </picture> <div class="builder-image-sizer" style="width: 100%;padding-top: 94.5%;pointer-events: none;font-size: 0;"></div> </div> </div> </div> <div class="builder-column" style="line-height: normal;display: flex;flex-direction: column;align-items: stretch;" > <div class="builder-blocks" builder-type="blocks">  <div class="builder-block builder-f97455f">  <div class="builder-block builder-3e49d9b">  <span class="builder-text"> HOME OF MONSTERS </span> </div>  <div class="builder-block builder-121adec">  <span class="builder-text"> <p>Falcon Lake is a wild, drought-scarred reservoir known for giant bass, prehistoric gar, and trophy catfish that turn every cast into a gamble.</p> </span> </div>  <div class="builder-block builder-647a6ae">  <div class="builder-block builder-97d3598"> {%- assign _use_img_url = 'https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?width=20' -%} <picture> <source srcset="https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?format=webp&width=100 100w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?format=webp&width=200 200w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?format=webp&width=400 400w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?format=webp&width=800 800w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?format=webp&width=1200 1200w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?format=webp&width=1600 1600w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?format=webp&width=2000 2000w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?width=20&format=webp 20w" type="image/webp" /> <img alt="" loading="lazy" src="{{ _use_img_url }}" sizes="(max-width: 638px) 4vw, (max-width: 998px) 3vw, 2vw" style="object-fit: contain;object-position: center;position: absolute;height: 100%;width: 100%;left: 0px;top: 0px;" /> </picture> <div class="builder-image-sizer" style="width: 100%;padding-top: 73%;pointer-events: none;font-size: 0;"></div> </div>  <div class="builder-block builder-33a6678">  <span class="builder-text"> <p>Falcon has produced <strong>bass over 13 lbs</strong> as well as blue and flathead catfish well over 50–70 lbs.</p> </span> </div> </div>  <div class="builder-block builder-4ff16e8">  <div class="builder-block builder-a506e74"> {%- assign _use_img_url = 'https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?width=20' -%} <picture> <source srcset="https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?format=webp&width=100 100w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?format=webp&width=200 200w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?format=webp&width=400 400w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?format=webp&width=800 800w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?format=webp&width=1200 1200w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?format=webp&width=1600 1600w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?format=webp&width=2000 2000w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?width=20&format=webp 20w" type="image/webp" /> <img alt="" loading="lazy" src="{{ _use_img_url }}" sizes="(max-width: 638px) 4vw, (max-width: 998px) 3vw, 2vw" style="object-fit: contain;object-position: center;position: absolute;height: 100%;width: 100%;left: 0px;top: 0px;" /> </picture> <div class="builder-image-sizer" style="width: 100%;padding-top: 73%;pointer-events: none;font-size: 0;"></div> </div>  <div class="builder-block builder-30b030d">  <span class="builder-text"> The lake holds alligator gar topping 200 lbs. </span> </div> </div>  <div class="builder-block builder-de1fbf2">  <div class="builder-block builder-68822c8"> {%- assign _use_img_url = 'https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?width=20' -%} <picture> <source srcset="https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?format=webp&width=100 100w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?format=webp&width=200 200w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?format=webp&width=400 400w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?format=webp&width=800 800w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?format=webp&width=1200 1200w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?format=webp&width=1600 1600w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?format=webp&width=2000 2000w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?width=20&format=webp 20w" type="image/webp" /> <img alt="" loading="lazy" src="{{ _use_img_url }}" sizes="(max-width: 638px) 4vw, (max-width: 998px) 3vw, 2vw" style="object-fit: contain;object-position: center;position: absolute;height: 100%;width: 100%;left: 0px;top: 0px;" /> </picture> <div class="builder-image-sizer" style="width: 100%;padding-top: 73%;pointer-events: none;font-size: 0;"></div> </div>  <div class="builder-block builder-3e66314">  <span class="builder-text"> The lake covers submerged Spanish colonial settlements, roads, and churches, creating ghostly structures that makes Falcon one of the most unique fisheries in the world. </span> </div> </div>  <div class="builder-block builder-1e950ae">  <div class="builder-block builder-1e2a5d2"> {%- assign _use_img_url = 'https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?width=20' -%} <picture> <source srcset="https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?format=webp&width=100 100w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?format=webp&width=200 200w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?format=webp&width=400 400w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?format=webp&width=800 800w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?format=webp&width=1200 1200w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?format=webp&width=1600 1600w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?format=w