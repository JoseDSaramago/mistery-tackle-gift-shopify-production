{%- for block in section.blocks -%}
  {%- if block.type == "sticker" and block.settings.image -%}
    <style>
      #sticker-{{ block.id }} {
        position: absolute;
        width: {{ block.settings.width }}px;
        z-index: {%- if block.settings.layer_order == "above" -%}2{%- else -%}0{%- endif -%};
        {%- assign tX = "0" -%}
        {%- assign tY = "0" -%}

        {%- case block.settings.horizontal_position -%}
          {%- when "left" -%} left: calc({{ block.settings.offset_x }}px); right: initial;
          {%- when "center" -%} left: 50%; {%- assign tX = "calc(-50% + " | append: block.settings.offset_x | append: "px)" -%}
          {%- when "right" -%} right: calc({{ block.settings.offset_x }}px); left: initial;
        {%- endcase -%}

        {%- case block.settings.vertical_position -%}
          {%- when "top_section" -%} top: calc({{ block.settings.offset_y }}px); bottom: initial;
          {%- when "top_content" -%} top: calc({{ block.settings.offset_y }}px + var(--section-vertical-padding)); bottom: initial;
          {%- when "center" -%} top: 50%; {%- assign tY = "calc(-50% + " | append: block.settings.offset_y | append: "px)" -%}
          {%- when "bottom_content" -%} bottom: calc({{ block.settings.offset_y }}px + var(--section-vertical-padding)); top: initial;
          {%- when "bottom_section" -%} bottom: calc({{ block.settings.offset_y }}px); top: initial;
        {%- endcase -%}

        transform: translateX({{ tX }}) translateY({{ tY }}) rotate({{ block.settings.rotation }}deg);
      }

      #sticker-{{ block.id }} img {
        width: {{ block.settings.width }}px !important;
        max-width: {{ block.settings.width }}px !important;
      }

      {%- for i in (1..3) -%}
        {%- assign visibility = "override_" | append: i | append: "_visibility" -%}
        {%- assign page_width = "override_" | append: i | append: "_page_width" -%}
        {%- assign width = "override_" | append: i | append: "_width" -%}
        {%- assign rotation = "override_" | append: i | append: "_rotation" -%}
        {%- assign layer_order = "override_" | append: i | append: "_layer_order" -%}
        {%- assign horiz = "override_" | append: i | append: "_horizontal_position" -%}
        {%- assign vert = "override_" | append: i | append: "_vertical_position" -%}
        {%- assign offset_x = "override_" | append: i | append: "_offset_x" -%}
        {%- assign offset_y = "override_" | append: i | append: "_offset_y" -%}
        {%- assign image = "override_" | append: i | append: "_image" -%}

        {%- if block.settings[visibility] != "disabled" -%}
          @media (max-width: {{ block.settings[page_width] }}px) {
            #sticker-{{ block.id }} {
              {%- if block.settings[visibility] == "hidden" -%}
                display: none;
              {%- else -%}
                display: block;
                width: {{ block.settings[width] }}px;
                z-index: {%- if block.settings[layer_order] == "above" -%}2{%- else -%}0{%- endif -%};

                {%- assign tX = "0" -%}
                {%- assign tY = "0" -%}

                {%- case block.settings[horiz] -%}
                  {%- when "left" -%} left: calc({{ block.settings[offset_x] }}px); right: initial;
                  {%- when "center" -%} left: 50%; {%- assign tX = "calc(-50% + " | append: block.settings[offset_x] | append: "px)" -%}
                  {%- when "right" -%} right: calc({{ block.settings[offset_x] }}px); left: initial;
                {%- endcase -%}

                {%- case block.settings[vert] -%}
                  {%- when "top_section" -%} top: calc({{ block.settings[offset_y] }}px); bottom: initial;
                  {%- when "top_content" -%} top: calc({{ block.settings[offset_y] }}px + var(--section-vertical-padding)); bottom: initial;
                  {%- when "center" -%} top: 50%; {%- assign tY = "calc(-50% + " | append: block.settings[offset_y] | append: "px)" -%}
                  {%- when "bottom_content" -%} bottom: calc({{ block.settings[offset_y] }}px + var(--section-vertical-padding)); top: initial;
                  {%- when "bottom_section" -%} bottom: calc({{ block.settings[offset_y] }}px); top: initial;
                {%- endcase -%}

                transform: translateX({{ tX }}) translateY({{ tY }}) rotate({{ block.settings[rotation] }}deg);
              {%- endif -%}
            }
            #sticker-{{ block.id }} img {
              width: {{ block.settings[width] }}px !important;
              max-width: {{ block.settings[width] }}px !important;
            }
            {%- if block.settings[image] -%}
              #sticker-{{ block.id }} .sticker-default { display: none !important; }
              {%- for j in (1..i) -%}
                #sticker-{{ block.id }} .sticker-override-{{ j }} {
                  {%- if j == i -%}display: block !important;{%- else -%}display: none !important;{%- endif -%}
                }
              {%- endfor -%}
            {%- else -%}
              #sticker-{{ block.id }} .sticker-default { display: block !important; }
              {%- for j in (1..i) -%}
                #sticker-{{ block.id }} .sticker-override-{{ j }} { display: none !important; }
              {%- endfor -%}
            {%- endif -%}
          }
        {%- endif -%}
      {%- endfor -%}
    </style>

    <div id="sticker-{{ block.id }}" class="sticker-block" {{ block.shopify_attributes }}>
      <div class="sticker-default">
        {% render "ante-image", image: block.settings.image, width: block.settings.width, alt: "Sticker", loading: "eager" %}
      </div>
      {%- for i in (1..3) -%}
        {%- assign visibility = "override_" | append: i | append: "_visibility" -%}
        {%- assign image = "override_" | append: i | append: "_image" -%}
        {%- assign width = "override_" | append: i | append: "_width" -%}
        {%- if block.settings[visibility] != "disabled" and block.settings[image] -%}
          <div class="sticker-override-{{ i }}" style="display: none;">
            {% render "ante-image", image: block.settings[image], width: block.settings[width], alt: "Sticker", loading: "eager" %}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- endif -%}
{%- endfor -%}
