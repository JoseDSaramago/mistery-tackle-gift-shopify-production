9bcab9%2F2af2b0fafab24f1a9cc14141d1b03028?format=webp&width=200 200w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F2af2b0fafab24f1a9cc14141d1b03028?format=webp&width=400 400w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F2af2b0fafab24f1a9cc14141d1b03028?format=webp&width=800 800w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F2af2b0fafab24f1a9cc14141d1b03028?format=webp&width=1200 1200w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F2af2b0fafab24f1a9cc14141d1b03028?format=webp&width=1600 1600w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F2af2b0fafab24f1a9cc14141d1b03028?format=webp&width=2000 2000w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F2af2b0fafab24f1a9cc14141d1b03028?width=20&format=webp 20w" type="image/webp" /> <img alt="" loading="lazy" src="{{ _use_img_url }}" sizes="(max-width: 638px) 4vw, (max-width: 998px) 3vw, 2vw" style="object-fit: contain;object-position: center;position: absolute;height: 100%;width: 100%;left: 0px;top: 0px;" /> </picture> <div class="builder-image-sizer" style="width: 100%;padding-top: 96.6%;pointer-events: none;font-size: 0;"></div> </div>  <div class="builder-block builder-a8f35b6">  <span class="builder-text"> ABOUT FALCON LAKE </span> </div>  <div class="builder-block builder-c8b423a"> {%- assign _use_img_url = 'https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F2af2b0fafab24f1a9cc14141d1b03028?width=20' -%} <picture> <source srcset="https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F2af2b0fafab24f1a9cc14141d1b03028?format=webp&width=100 100w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F2af2b0fafab24f1a9cc14141d1b03028?format=webp&width=200 200w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F2af2b0fafab24f1a9cc14141d1b03028?format=webp&width=400 400w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F2af2b0fafab24f1a9cc14141d1b03028?format=webp&width=800 800w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F2af2b0fafab24f1a9cc14141d1b03028?format=webp&width=1200 1200w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F2af2b0fafab24f1a9cc14141d1b03028?format=webp&width=1600 1600w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F2af2b0fafab24f1a9cc14141d1b03028?format=webp&width=2000 2000w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F2af2b0fafab24f1a9cc14141d1b03028?width=20&format=webp 20w" type="image/webp" /> <img alt="" loading="lazy" src="{{ _use_img_url }}" sizes="(max-width: 638px) 4vw, (max-width: 998px) 3vw, 2vw" style="object-fit: contain;object-position: center;position: absolute;height: 100%;width: 100%;left: 0px;top: 0px;" /> </picture> <div class="builder-image-sizer" style="width: 100%;padding-top: 96.6%;pointer-events: none;font-size: 0;"></div> </div> </div>  <div class="builder-block builder-ca06740">  <div class="builder-columns"> <div class="builder-column" style="line-height: normal;display: flex;flex-direction: column;align-items: stretch;" > <div class="builder-blocks" builder-type="blocks">  <div class="builder-block builder-19dc785">  <span class="builder-text"> WHERE FISHING HAS NO BORDERS </span> </div>  <div class="builder-block builder-f15f714">  <span class="builder-text"> <div>Falcon Lake sits on the Texas–Mexico border, where red-dirt roads meet blue water and the horizon hums with stories. Built in the 1950s by damming the Rio Grande, the lake swallowed old towns, churches, and roads—leaving a ghostly landscape that’s as mysterious as it is magnetic.</div><div><br></div><div>It’s legendary water for big bass, but it’s also a living crossroads of cultures. On any given day you’ll find Texas anglers working crankbaits through flooded brush while Mexican fishermen sling hand-lines from tin boats just a few hundred yards away. Different languages, same mission: chase the next strike.</div> </span> </div> </div> </div> <div class="builder-column" style="line-height: normal;display: flex;flex-direction: column;align-items: stretch;" > <div class="builder-blocks" builder-type="blocks">  <div class="builder-block builder-52d223e"> {%- assign _use_img_url = 'https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F8b551d1e1b804cd5bbcbd861965e3eb0?width=528' -%} <picture> <source srcset="https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F8b551d1e1b804cd5bbcbd861965e3eb0?format=webp&width=100 100w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F8b551d1e1b804cd5bbcbd861965e3eb0?format=webp&width=200 200w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F8b551d1e1b804cd5bbcbd861965e3eb0?format=webp&width=400 400w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F8b551d1e1b804cd5bbcbd861965e3eb0?format=webp&width=800 800w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F8b551d1e1b804cd5bbcbd861965e3eb0?format=webp&width=1200 1200w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F8b551d1e1b804cd5bbcbd861965e3eb0?format=webp&width=1600 1600w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F8b551d1e1b804cd5bbcbd861965e3eb0?format=webp&width=2000 2000w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F8b551d1e1b804cd5bbcbd861965e3eb0?width=528&format=webp 528w" type="image/webp" /> <img alt="" loading="lazy" src="{{ _use_img_url }}" sizes="(max-width: 638px) 83vw, (max-width: 998px) 53vw, 38vw" style="object-fit: cover;object-position: center;position: absolute;height: 100%;wid