8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?format=webp" type="image/webp" /> <img alt="" loading="lazy" src="{{ _use_img_url }}" sizes="(max-width: 638px) 4vw, (max-width: 998px) 3vw, 2vw" style="object-fit: contain;object-position: center;position: absolute;height: 100%;width: 100%;left: 0px;top: 0px;" /> </picture> <div class="builder-image-sizer" style="width: 100%;padding-top: 73%;pointer-events: none;font-size: 0;"></div> </div>  <div class="builder-block builder-d97e1ae">  <span class="builder-text"> The lake holds alligator gar topping 200 lbs. </span> </div> </div>  <div class="builder-block builder-c025105">  <div class="builder-block builder-9f3d2fb"> {%- assign _use_img_url = 'https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014' -%} <picture> <source srcset="https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?format=webp&width=100 100w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?format=webp&width=200 200w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?format=webp&width=400 400w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?format=webp&width=800 800w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?format=webp&width=1200 1200w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?format=webp&width=1600 1600w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?format=webp&width=2000 2000w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?format=webp" type="image/webp" /> <img alt="" loading="lazy" src="{{ _use_img_url }}" sizes="(max-width: 638px) 4vw, (max-width: 998px) 3vw, 2vw" style="object-fit: contain;object-position: center;position: absolute;height: 100%;width: 100%;left: 0px;top: 0px;" /> </picture> <div class="builder-image-sizer" style="width: 100%;padding-top: 73%;pointer-events: none;font-size: 0;"></div> </div>  <div class="builder-block builder-3bf16bd">  <span class="builder-text"> The lake covers submerged Spanish colonial settlements, roads, and churches, creating ghostly structures that makes Falcon one of the most unique fisheries in the world. </span> </div> </div>  <div class="builder-block builder-c88302f">  <div class="builder-block builder-a8be025"> {%- assign _use_img_url = 'https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014' -%} <picture> <source srcset="https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?format=webp&width=100 100w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?format=webp&width=200 200w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?format=webp&width=400 400w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?format=webp&width=800 800w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?format=webp&width=1200 1200w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?format=webp&width=1600 1600w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?format=webp&width=2000 2000w, https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F6ca5869b0ac14e28952f1da6d3980014?format=webp" type="image/webp" /> <img alt="" loading="lazy" src="{{ _use_img_url }}" sizes="(max-width: 638px) 4vw, (max-width: 998px) 3vw, 2vw" style="object-fit: contain;object-position: center;position: absolute;height: 100%;width: 100%;left: 0px;top: 0px;" /> </picture> <div class="builder-image-sizer" style="width: 100%;padding-top: 73%;pointer-events: none;font-size: 0;"></div> </div>  <div class="builder-block builder-cc11ac6">  <span class="builder-text"> Falcon’s remote location and proximity to the Mexico side have spawned decades of stories—from border patrol sightings to cartel-era cautionary tales—adding to the lake’s rugged reputation anglers whisper about at the ramp. </span> </div> </div> </div> </div> </div>  </div> </div> </div> </div> </div>  <div class="builder-block builder-2df4495"> <div style="height: 100%;width: 100%;align-self: stretch;flex-grow: 1;box-sizing: border-box;max-width: 1200px;display: flex;flex-direction: column;align-items: stretch;margin-left: auto;margin-right: auto;"> </div> </div>  <div class="builder-block builder-83eff56"> <div style="height: 100%;width: 100%;align-self: stretch;flex-grow: 1;box-sizing: border-box;max-width: 1200px;display: flex;flex-direction: column;align-items: stretch;margin-left: auto;margin-right: auto;">  <div class="builder-block builder-1adef31">  <div class="builder-columns"> <div class="builder-column" style="line-height: normal;display: flex;flex-direction: column;align-items: stretch;" > <div class="builder-blocks" builder-type="blocks">  <div class="builder-block builder-640b0c2">  <div class="builder-block builder-07ebb07 ribbon">  <span class="builder-text"> <p>MERCH DROP</p> </span> </div>  <div class="builder-block builder-e66b742"> {%- assign _use_img_url = 'https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%2F7808f3e2c1c0431aa51ddf4e836d75c8?width=272' -%} <picture> <source srcset="https://cdn.builder.io/api/v1/image/assets%2Fb8b1ee6e88d8463eaa4fdc39659bcab9%