{% assign id = "ante-footer" %}

<style>
  #shopify-section-{{ section.id }} {
    position: sticky;
    bottom: 0;
    z-index: 0 !important;
    flex: 1;
    display: flex !important;
    flex-direction: column;
    justify-content: flex-end;
    opacity: 0;
  }

  #{{ id }} {
    background-image: url({{ section.settings.background_image | image_url: width: section.settings.background_image.width }});
    background-size: cover;
    background-position: center;
  }

  #{{ id }}::before {
    display: none;
  }

  #{{ id }} .ante-section-content {
    flex-direction: row;
    flex-wrap: wrap;
    column-gap: var(--spacing-large);
    row-gap: var(--spacing-medium);
  }

  #{{ id }} a {
    color: var(--color-text-default);
    text-decoration: none;
    position: relative;
  }

  #{{ id }} a.body-caption::before {
    content: "";
    position: absolute;
    bottom: 2px;
    width: 0;
    left: 50%;
    transform: translateX(-50%);
    height: 1px;
    transition: width .25s;
  }

  #{{ id }} a.body-caption:hover::before {
    width: 100%;
  }

  #{{ id }} .footer-left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    max-width: var(--width-5);
  }

  #{{ id }} .footer-left > .ante-image {
    margin-bottom: var(--spacing-medium);
  }

  #{{ id }} .description {
    margin-bottom: var(--spacing-x-small);
  }

  #{{ id }} .socials {
    display: flex;
    gap: var(--micropad-x-large);
  }

  #{{ id }} .socials img {
    width: 44px;
    height: 44px;
  }

  #{{ id }} .footer-right {
    display: flex;
    gap: var(--spacing-medium);
    flex: 1;
    justify-content: flex-end;
  }

  #{{ id }} .footer-menu {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-x-small);
    width: 220px;
  }

  #{{ id }} .footer-menu-links {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--micropad-large);
  }

  #{{ id }} .footer-bottom {
    width: 100%;
    display: flex;
    gap: var(--micropad-x-large);
    align-items: center;
  }

  #{{ id }} .payment-icons {
    display: flex;
    gap: var(--micropad-x-small);
  }

  #{{ id }} .footer-bottom-links {
    display: flex;
    gap: var(--micropad-x-large);
    align-items: center;
    flex: 1;
  }

  #{{ id }} form {
    margin-bottom: var(--spacing-x-small);
    width: var(--width-4);
  }

  @media (max-width: 1919px) {
    #{{ id }} .footer-menu {
      width: 160px;
    }

    #{{ id }} .footer-left > .ante-image {
      height: 110px;
    }
  }

  @media (max-width: 1350px) {
    #{{ id }} .footer-left {
      max-width: var(--width-4);
    }
  }

  @media (max-width: 1024px) {
    #{{ id }} .ante-section-content {
      flex-direction: column;
    }

    #{{ id }} .footer-left {
      max-width: var(--width-6);
    }

    #{{ id }} .footer-left {
      align-items: center;
    }

    #{{ id }} .footer-left > .ante-image {
      height: 100px;
    }

    #{{ id }} .description {
      text-align: center;
    }

    #{{ id }} .footer-right {
      gap: var(--spacing-x-small);
    }

    #{{ id }} .footer-menu {
      width: 180px;
      text-align: center;
    }

    #{{ id }} .footer-menu-links {
      align-items: center;
    }

    #{{ id }} .footer-bottom {
      flex-direction: column;
    }

    #{{ id }} .credit {
      margin-top: calc(var(--micropad-x-large) * -1);
      padding-top: var(--padding-medium);
    }

    #{{ id }} form {
      width: 100%;
    }
  }

  @media (max-width: 600px) {
    #{{ id }} .footer-left {
      max-width: 100%;
    }

    #{{ id }} .footer-left > .ante-image {
      height: 78px;
    }

    #{{ id }} .footer-right {
      flex-wrap: wrap;
      column-gap: var(--spacing-x-small);
      row-gap: var(--spacing-medium);
      width: 100%;
    }

    #{{ id }} .footer-menu {
      width: initial;
      flex: 1 1 0px;
      min-width: 128px;
    }
  }
</style>

{% render "ante-section-structure", section: section, id: id %}
  <div class="footer-left">
    {% render "ante-image", image: section.settings.logo %}
    {% if section.settings.description != blank %}
      <div class="description body-base bold richtext inverse">{{ section.settings.description }}</div>
    {% endif %}
    <form method="post" action="/contact#newsletter">
      <input type="hidden" name="form_type" value="customer">
      <input type="hidden" name="contact[tags]" value="newsletter">
      <div class="ante-input-with-button">
        <input type="email" name="contact[email]" placeholder="Email address" required>
        <button type="submit">SIGN UP</button>
      </div>
    </form>
    <div class="socials">
      {% for block in section.blocks %}
        {% if block.type == "social_media" and block.settings.icon %}
          <a href="{{ block.settings.link }}" target="_blank">
            {% render "ante-image", image: block.settings.icon, height: 44 %}
          </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
  <div class="footer-right">
    {% for block in section.blocks %}
      {% if block.type == "menu" and block.settings.menu != blank %}
        <div class="footer-menu">
          {% if block.settings.name != blank %}
            <h6>{{ block.settings.name }}</h6>
          {% endif %}
          <div class="footer-menu-links">
            {% for link in block.settings.menu.links %}
              <a class="body-caption muted-inverse" href="{{ link.url }}">{{ link.title }}</a>
            {% endfor %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
  <div class="footer-bottom">
    <div class="payment-icons">
      {% for block in section.blocks %}
        {% if block.type == "payment_icon" and block.settings.icon %}
          {% render "ante-image", image: block.settings.icon, height: 24 %}
        {% endif %}
      {% endfor %}
    </div>
    <div class="footer-bottom-links">
      {% if section.settings.legal_menu != blank %}
        {% for link in section.settings.legal_menu.links %}
          <a class="body-caption" href="{{ link.url }}">{{ link.title }}</a>
        {% endfor %}
      {% endif %}
      <div class="body-caption">©{{ "now" | date: "%Y" }} {{ shop.name }}</div>
    </div>
    {% if section.settings.credit != blank %}
      <a class="body-caption alt credit" href="{{ section.settings.credit_link | default: "https://ante.studio/" }}" target="_blank">{{ section.settings.credit }}</a>
    {% endif %}
  </div>
{% render "ante-section-structure", end: true %}

<script type="module">
  const footer = document.getElementById("ante-footer").parentElement
  const prev = footer.previousElementSibling

  footer.style.opacity = "0"

  function updateFooterOpacity() {
    const rect = prev.getBoundingClientRect()
    footer.style.opacity = rect.bottom <= window.innerHeight ? "1" : "0"
  }

  window.addEventListener("scroll", updateFooterOpacity, { passive: true })
  window.addEventListener("resize", updateFooterOpacity)
  updateFooterOpacity()
</script>

