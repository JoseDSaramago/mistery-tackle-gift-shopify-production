{%- liquid
  assign eyebrow = section.settings.eyebrow
  assign title = section.settings.title
  assign subtitle = section.settings.subtitle
  assign show_promo = section.settings.show_promo_banner
  assign promo_text = section.settings.promo_banner_text
  assign bg_image = section.settings.background_image
  assign bg_image_mobile = section.settings.background_image_mobile
-%}

<style>
  #shopify-section-{{ section.id }} {
    /* Colores */
    --gp-hero-bg-color: {{ section.settings.bg_color }};
    --gp-hero-text-color: {{ section.settings.text_color }};
    --gp-hero-promo-bg: {{ section.settings.promo_bg_color }};
    --gp-hero-promo-color: {{ section.settings.promo_text_color }};

    /* Spacing mobile-first */
    --gp-hero-pad-top: {{ section.settings.padding_top_mobile }}px;
    --gp-hero-pad-bottom: {{ section.settings.padding_bottom_mobile }}px;

    /* Background image */
    {%- if bg_image_mobile != blank -%}
      --gp-hero-bg-image: url('{{ bg_image_mobile | image_url: width: 600 }}');
    {%- elsif bg_image != blank -%}
      --gp-hero-bg-image: url('{{ bg_image | image_url: width: 600 }}');
    {%- else -%}
      --gp-hero-bg-image: none;
    {%- endif -%}
  }

  @media screen and (min-width: 768px) {
    #shopify-section-{{ section.id }} {
      --gp-hero-pad-top: {{ section.settings.padding_top_desktop }}px;
      --gp-hero-pad-bottom: {{ section.settings.padding_bottom_desktop }}px;

      {%- if bg_image != blank -%}
        --gp-hero-bg-image: url('{{ bg_image | image_url: width: 1920 }}');
      {%- endif -%}
    }
  }
</style>

<section class="gift-plans__hero" aria-label="{{ title }}">
  <div class="gift-plans__hero-content page-width">

    {%- if eyebrow != blank -%}
      <span class="gift-plans__hero-eyebrow">{{ eyebrow }}</span>
    {%- endif -%}

    {%- if title != blank -%}
      <h1 class="gift-plans__hero-title">{{ title }}</h1>
    {%- endif -%}

    {%- if subtitle != blank -%}
      <p class="gift-plans__hero-subtitle">{{ subtitle }}</p>
    {%- endif -%}

    {%- if section.settings.show_cta -%}
      <a href="{{ section.settings.cta_url }}" class="gift-plans__hero-cta">
        {{ section.settings.cta_text }}
      </a>
    {%- endif -%}

  </div>

  {%- if show_promo and promo_text != blank -%}
    <div class="gift-plans__hero-promo" role="status">
      <div class="page-width">
        <p class="gift-plans__hero-promo-text">{{ promo_text }}</p>
      </div>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Gift Plans Hero",
  "tag": "section",
  "class": "gift-plans-hero-section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "MYSTERY TACKLE BOX"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "GIFT PLAN"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Give the #1 fishing gift: a unique tackle discovery box for all skill levels shipped monthly"
    },
    {
      "type": "header",
      "content": "Call to Action"
    },
    {
      "type": "checkbox",
      "id": "show_cta",
      "label": "Show CTA Button",
      "default": false
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Text",
      "default": "Build Your Gift"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA Link"
    },
    {
      "type": "header",
      "content": "Promo Banner"
    },
    {
      "type": "checkbox",
      "id": "show_promo_banner",
      "label": "Show Promo Banner",
      "default": true
    },
    {
      "type": "text",
      "id": "promo_banner_text",
      "label": "Promo Banner Text",
      "default": "🔥 SAVE 15% off all gift plans • No code needed • Discount applied in cart 🔥"
    },
    {
      "type": "color",
      "id": "promo_bg_color",
      "label": "Promo Background Color",
      "default": "#dd5739"
    },
    {
      "type": "color",
      "id": "promo_text_color",
      "label": "Promo Text Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image (Desktop)"
    },
    {
      "type": "image_picker",
      "id": "background_image_mobile",
      "label": "Background Image (Mobile)",
      "info": "If empty, uses the desktop image"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#31554b"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding Top (Mobile)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom (Mobile)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding Top (Desktop)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding Bottom (Desktop)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Gift Plans Hero"
    }
  ]
}
{% endschema %}
