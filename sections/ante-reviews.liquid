{% assign id = section.settings.custom_id | default: section.id %}

<style>
  #{{ id }} .ante-section-content {
    gap: var(--spacing-medium);
  }

  #{{ id }} .review-grid {
    width: 100%;
    max-width: var(--width-9);
  }

  #{{ id }} .review-item {
    background-color: var(--color-surface-100);
    border-radius: var(--radius-large);
    overflow: hidden;
    min-width: calc(100% / 3 - (var(--spacing-small) * 2) / 3);
    max-width: calc(100% / 3 - (var(--spacing-small) * 2) / 3);
    margin-bottom: var(--spacing-small);
    border: 1px solid var(--color-border);
  }

  #{{ id }} .review-item:first-child,
  #{{ id }} .review-item:nth-child(3) {
    margin-top: var(--spacing-large);
  }

  #{{ id }} .ante-image {
    border-radius: 0;
  }

  #{{ id }} img {
    width: 100%;
  }

  #{{ id }} .review-content {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-x-small);
    padding: var(--padding-small);
  }

  @media (max-width: 1919px) {
    #{{ id }} img {
      height: 148px;
    }
  }

  @media (max-width: 1024px) {
    #{{ id }} .review-grid {
      max-width: 100%;
    }

    #{{ id }} .review-item {
      min-width: calc(50% - var(--spacing-small) / 2);
      max-width: calc(50% - var(--spacing-small) / 2);
      margin-top: 0 !important;
    }

    #{{ id }} img {
      height: 136px;
    }
  }

  @media (max-width: 600px) {
    #{{ id }} .review-content {
      padding: var(--padding-medium);
    }
  }

  @media (max-width: 550px) {
    #{{ id }} .review-grid {
      max-width: 100%;
    }

    #{{ id }} .review-item {
      min-width: 100%;
      max-width: 100%;
    }

    #{{ id }} img {
      height: 167px;
    }
  }
</style>

{% render "ante-section-structure", section: section %}
  <div class="review-grid">
    {% assign index = 0 %}
    {% for block in section.blocks %}
      {% if block.type == "review" %}
        {% assign index = index | plus: 1 %}
        <div class="review-item{% if index > section.settings.mobile_limit %} desktop{% endif %}">
          {% if block.settings.image %}
            {% render "ante-image", image: block.settings.image, height: 194 %}
          {% endif %}
          <div class="review-content">
            {% render "ante-stars", rating: block.settings.star_rating %}
            <h5>{{ block.settings.heading }}</h5>
            <div>"{{ block.settings.review }}"</div>
            <div class="body-caption">{{ block.settings.name }}</div>
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
  {% if section.settings.button_url %}
    <a class="ante-button" href="{{ section.settings.button_url }}" target="_blank">{{ section.settings.button_text }}</a>
  {% endif %}
{% render "ante-section-structure", end: true %}

<script type="module">
  const grid = document.querySelector("#{{ id }} .review-grid")

  const masonry = new Masonry(grid, {
    itemSelector: ".review-item",
    columnWidth: ".review-item",
    percentPosition: true
  })

  function updateGutter() {
    const spacing = parseFloat(
      getComputedStyle(document.documentElement).getPropertyValue("--spacing-small")
    )
    masonry.options.gutter = spacing
    masonry.layout()
  }

  updateGutter()
  window.addEventListener("resize", updateGutter)

  grid.querySelectorAll("img").forEach(img => {
    if (img.complete) {
      masonry.layout()
    } else {
      img.addEventListener("load", () => masonry.layout())
      img.addEventListener("error", () => masonry.layout())
    }
  })
</script>

