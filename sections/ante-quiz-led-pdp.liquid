  #{{ id }} .qz-brand-tile { aspect-ratio: 16/9; background: #fff; border: 1px dashed rgba(16,24,32,.25); border-radius: 16px; display: flex; align-items: center; justify-content: center; font-family: var(--font-body); font-weight: 700; font-size: 9px; letter-spacing: .14em; color: rgba(16,24,32,.55); text-align: center; padding: 6px; line-height: 1.2; overflow: hidden; }
  @media (min-width: 900px) { #{{ id }} .qz-brand-tile { font-size: 10px; } }
  #{{ id }} .qz-brand-tile img { max-height: 80%; max-width: 80%; object-fit: contain; }
