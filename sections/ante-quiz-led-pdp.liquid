{%- comment -%}
  ante-quiz-led-pdp.liquid
  Quiz-led Paid-Social PDP — V2 from the design handoff.
  Mirrors the block schema of ante-pdp-004-buybox so existing product/subscription_product
  JSON can be lifted directly. Adds a `species` block + per-product recommendation mapping.
{%- endcomment -%}

{%- assign id = section.settings.custom_id | default: section.id -%}

{%- comment -%} ── Build species + recommendation maps from blocks ── {%- endcomment -%}
{%- assign species_blocks = section.blocks | where: "type", "species" -%}
{%- assign product_blocks = section.blocks | where: "type", "product" -%}
{%- assign sub_blocks = section.blocks | where: "type", "subscription_product" -%}
{%- assign info_blocks = section.blocks | where: "type", "info" -%}

{%- comment -%} Determine default tier (preselected product block) {%- endcomment -%}
{%- assign default_tier_id = blank -%}
{%- for b in product_blocks -%}
  {%- if b.settings.preselected and default_tier_id == blank -%}
    {%- assign default_tier_id = b.id -%}
  {%- endif -%}
{%- endfor -%}
{%- if default_tier_id == blank and product_blocks.size > 0 -%}
  {%- assign default_tier_id = product_blocks[0].id -%}
{%- endif -%}

<section
  id="{{ id }}"
  class="ante-section quiz-led-pdp {% if section.settings.section_inverse %}ante-inverse {% endif %}{{ section.settings.section_background_style }} {{ section.settings.section_background_colour }} {{ section.settings.section_spacing }}{% if section.settings.section_visible == false %} ante-section-hidden{% endif %}"
  data-quiz-id="quiz-{{ section.id }}"
  data-default-tier="{{ default_tier_id }}"
  data-default-plan="{{ section.settings.default_plan_key | default: '6' }}"
  data-discount-code="{{ section.settings.discount_code }}"
>
  <div class="qz-wrap">

    {%- comment -%} ── Section announcement bar (above the progress) ── {%- endcomment -%}
    {%- if section.settings.announce_text != blank -%}
      <div class="qz-announce qz-announce--{{ section.settings.announce_align | default: 'full' }}"
           style="background: {{ section.settings.announce_background | default: '#FFCB12' }};">
        {{ section.settings.announce_text }}
      </div>
    {%- endif -%}

    {%- comment -%} ── Progress bar ── {%- endcomment -%}
    <div class="qz-progress" data-qz-progress>
      <div class="qz-progress-row">
        <span class="qz-step-label" data-qz-step-label>STEP 1 OF 3</span>
        <span class="qz-takes">{{ section.settings.takes_label | default: 'Takes 20 seconds' }}</span>
      </div>
      <div class="qz-progress-track"><div class="qz-progress-fill" data-qz-progress-fill></div></div>
      <button type="button" class="qz-back" data-qz-back hidden aria-label="Go back one step">← {{ section.settings.back_label | default: 'Back' }}</button>
    </div>

    {%- comment -%} ── Step 0 · Intro ── {%- endcomment -%}
    <div class="qz-step" data-qz-step="0">
      <div class="qz-kicker">— {{ section.settings.intro_kicker | default: 'Fishing Simplified' }} —</div>
      <h1 class="qz-display qz-display-xl">{{ section.settings.intro_heading | default: '<p>Find the box <em>that fits</em> your fishing.</p>' }}</h1>
      <div class="qz-lede">{{ section.settings.intro_lede | default: '<p>Two taps. We&rsquo;ll match you to the right box, plan and species. Your $10 off is already locked in.</p>' }}</div>
      <div class="qz-rating">
        {% render "ante-stars", rating: section.settings.star_rating | default: 4.5 %}
        <span>{{ section.settings.star_review_text | default: '4.5 · 7,754 reviews' }}</span>
      </div>
      <button type="button" class="qz-cta" data-qz-go="1">{{ section.settings.intro_cta | default: 'Start · 20 seconds' }}</button>
      <button type="button" class="qz-skip" data-qz-go="3">{{ section.settings.skip_cta | default: 'Skip the quiz, show me the boxes' }}</button>
    </div>

    {%- comment -%} ── Step 1 · Species ── {%- endcomment -%}
    <div class="qz-step" data-qz-step="1" hidden>
      <h2 class="qz-display qz-display-lg">{{ section.settings.step1_heading | default: 'What do you fish?' }}</h2>
      <p class="qz-sub">{{ section.settings.step1_sub | default: "We&rsquo;ll pack your box with baits proven to catch it." }}</p>
      <div class="qz-species-grid">
        {%- for s in species_blocks -%}
          <button type="button" class="qz-species-tile"
            data-qz-species="{{ s.id }}"
            data-qz-species-color="{{ s.settings.color | default: '#33534B' }}"
            data-qz-species-name="{{ s.settings.name | escape }}"
            {{ s.shopify_attributes }}>
            <span class="qz-species-swatch" style="background:{{ s.settings.color | default: '#33534B' }}">
              {%- if s.settings.image != blank -%}
                <img src="{{ s.settings.image | image_url: width: 160 }}" alt="" loading="lazy">
              {%- endif -%}
            </span>
            <span class="qz-species-name">{{ s.settings.name }}</span>
            <span class="qz-species-arrow">›</span>
          </button>
        {%- endfor -%}
      </div>
    </div>

    {%- comment -%} ── Step 2 · Skill ── {%- endcomment -%}
    <div class="qz-step" data-qz-step="2" hidden>
      <h2 class="qz-display qz-display-lg">{{ section.settings.step2_heading | default: "What&rsquo;s your skill level?" }}</h2>
      <p class="qz-sub">{{ section.settings.step2_sub | default: 'Helps us match the right tackle mix &mdash; beginner-friendly or pro-grade.' }}</p>
      <div class="qz-skill-grid">
        {%- assign skill_keys = "new,growing,expert" | split: "," -%}
        {%- assign skill_setting_keys = "skill_new,skill_growing,skill_expert" | split: "," -%}
        {%- assign skill_defaults_label = "New to fishing,Getting serious,Experienced angler" | split: "," -%}
        {%- assign skill_defaults_sub = "Learning the ropes &middot; need the basics,Know what works&comma; building my arsenal,Chasing variety + premium gear" | split: "," -%}
        {%- for sk in skill_keys -%}
          {%- assign idx = forloop.index0 -%}
          {%- assign label_key = skill_setting_keys[idx] | append: "_label" -%}
          {%- assign sub_key = skill_setting_keys[idx] | append: "_sub" -%}
          <button type="button" class="qz-skill-tile" data-qz-skill="{{ sk }}">
            <span class="qz-skill-num">0{{ forloop.index }}</span>
            <span class="qz-skill-label">{{ section.settings[label_key] | default: skill_defaults_label[idx] }}</span>
            <span class="qz-skill-sub">{{ section.settings[sub_key] | default: skill_defaults_sub[idx] }}</span>
          </button>
        {%- endfor -%}
      </div>
    </div>

    {%- comment -%} ── Step 3 · Result / Buy ── {%- endcomment -%}
    <div class="qz-step qz-result" data-qz-step="3" hidden>
      <div class="qz-result-grid">

        <div class="qz-result-image">
          <div class="qz-gallery" data-qz-gallery>
            <div class="qz-gallery-main" data-qz-gallery-main>
              <img class="qz-gallery-img is-active" data-qz-gallery-slot="main" src="" alt="" loading="lazy">
            </div>
            <div class="qz-stamp">{{ section.settings.match_stamp | default: 'YOUR MATCH' }}</div>
          </div>
          <div class="qz-gallery-thumbs" data-qz-gallery-thumbs role="tablist" aria-label="Product gallery"></div>
        </div>

        <div class="qz-result-body">
          <div class="qz-stamp qz-stamp-mobile">{{ section.settings.match_stamp | default: 'YOUR MATCH' }}</div>
          <div class="qz-kicker">— {{ section.settings.result_kicker | default: 'We recommend' }} —</div>
          <h2 class="qz-display qz-result-display">
            <span data-qz-tier-headline>The {{ product_blocks[0].settings.custom_name | default: 'Pro Box' }}</span>
          </h2>
          <p class="qz-result-lede">
            Paired with your <strong data-qz-species-strong>Bass</strong> picks on <span data-qz-plan-prefix>our recommended</span> <strong data-qz-plan-label>6-month</strong> plan.
          </p>

          {%- comment -%} Plan length selector {%- endcomment -%}
          <div class="qz-kicker">— {{ section.settings.plan_kicker | default: 'Plan length' }} —</div>
          <div class="qz-plan-grid" data-qz-plan-grid>
            {%- assign plan_keys = "1,4,6,12" | split: "," -%}
            {%- for pk in plan_keys -%}
              <button type="button" class="qz-plan-btn" data-qz-plan="{{ pk }}">
                <span class="qz-plan-short">{{ pk }} mo</span>
                {%- if pk != "1" -%}
                  <span class="qz-plan-badge qz-plan-badge-top">$10 OFF</span>
                {%- endif -%}
                {%- if pk == "6" -%}
                  <span class="qz-plan-badge qz-plan-badge-bottom" data-qz-plan-bottom-badge>BEST</span>
                {%- endif -%}
              </button>
            {%- endfor -%}
          </div>

          {%- comment -%} Recommendation card {%- endcomment -%}
          <div class="qz-rec-card">
            <div class="qz-rec-row">
              <div class="qz-rec-icon" data-qz-rec-icon>
                <span data-qz-rec-icon-letter>P</span>
                <img class="qz-rec-icon-img" data-qz-rec-icon-img src="" alt="" hidden>
              </div>
              <div class="qz-rec-meta">
                <div class="qz-rec-tier" data-qz-rec-tier>PRO BOX</div>
                <div class="qz-rec-detail"><span data-qz-rec-items>6&ndash;8</span> pro-picked items &middot; <span data-qz-rec-planlabel>6-month</span></div>
                <div class="qz-rec-prices">
                  <span class="qz-rec-retail" data-qz-rec-retail>$240.00</span>
                  <span class="qz-rec-total" data-qz-rec-total>$189.99</span>
                  <span class="qz-rec-permo">&middot; <span data-qz-rec-permo>$31.66</span>/mo</span>
                </div>
              </div>
            </div>
            <div class="qz-ship qz-ship-free" data-qz-ship-free>
              <strong>+ FREE SHIPPING</strong> included
            </div>
            <div class="qz-ship qz-ship-paid" data-qz-ship-paid hidden>
              + shipping &middot; renews monthly. Upgrade to 4+ months for free shipping.
            </div>
            <div class="qz-savings" data-qz-savings>You save $<span data-qz-save-amount>60</span> vs retail</div>
          </div>

          {%- comment -%} Buy form ── posts variant id to /cart/add {%- endcomment -%}
          <form action="{{ routes.cart_add_url }}" method="post" enctype="multipart/form-data" class="qz-buy-form" data-qz-buy-form>
            <input type="hidden" name="id" value="" data-qz-variant-id>
            <input type="hidden" name="quantity" value="1">
            <input type="hidden" name="selling_plan" value="" data-qz-selling-plan disabled>
            {%- if section.settings.discount_code != blank -%}
              <input type="hidden" name="attributes[Discount Code]" value="{{ section.settings.discount_code }}">
            {%- endif -%}
            <button type="submit" class="qz-cta">
              <span data-qz-cta-label>Start my Pro &middot; $10 OFF</span>
            </button>
          </form>
          <div class="qz-fineprint">{{ section.settings.fineprint | default: 'Cancel anytime &middot; First box ships within 24 hours' }}</div>

          <div class="qz-restart">
            <div class="qz-restart-label">Want a different match? Start over.</div>
            <div class="qz-restart-btns">
              <button type="button" class="qz-secondary" data-qz-go="1">↻ Change species</button>
              <button type="button" class="qz-secondary" data-qz-go="1" data-qz-retake>↻ Retake quiz</button>
            </div>
          </div>
        </div>
      </div>
    </div>

    {%- comment -%} ── Risk row ── {%- endcomment -%}
    {%- if info_blocks.size > 0 -%}
      <div class="qz-risk-row">
        {%- for info in info_blocks -%}
          <div class="qz-risk">
            {%- if info.settings.image != blank -%}
              <img src="{{ info.settings.image | image_url: width: 80 }}" alt="" loading="lazy">
            {%- endif -%}
            <div>
              <div class="qz-risk-h">{{ info.settings.text }}</div>
              <div class="qz-risk-s">{{ info.settings.description }}</div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>

  {%- comment -%} ── Press marquee ── {%- endcomment -%}
  {%- assign press_blocks = section.blocks | where: "type", "press_item" -%}
  {%- if press_blocks.size > 0 -%}
    <div class="qz-press">
      <div class="qz-press-kicker">— {{ section.settings.press_kicker | default: 'As seen in' }} —</div>
      <div class="qz-marquee">
        {%- for it in press_blocks -%}
          <div class="qz-press-item">
            {%- if it.settings.logo != blank -%}
              <img class="qz-press-logo" src="{{ it.settings.logo | image_url: width: 200 }}" alt="{{ it.settings.label | escape }}" loading="lazy">
            {%- else -%}
              <div class="qz-press-logo qz-press-logo-placeholder">{{ it.settings.label | default: 'LOGO' }}</div>
            {%- endif -%}
            <div class="qz-press-quote">{{ it.settings.quote }}</div>
          </div>
        {%- endfor -%}
        {%- for it in press_blocks -%}
          <div class="qz-press-item" aria-hidden="true">
            {%- if it.settings.logo != blank -%}
              <img class="qz-press-logo" src="{{ it.settings.logo | image_url: width: 200 }}" alt="" loading="lazy">
            {%- else -%}
              <div class="qz-press-logo qz-press-logo-placeholder">{{ it.settings.label | default: 'LOGO' }}</div>
            {%- endif -%}
            <div class="qz-press-quote">{{ it.settings.quote }}</div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} ── Reviews strip (mobile marquee, desktop 5-up grid) ── {%- endcomment -%}
  {%- assign review_blocks = section.blocks | where: "type", "review" -%}
  {%- if review_blocks.size > 0 -%}
    <div class="qz-reviews">
      <div class="qz-reviews-head">
        <div class="qz-reviews-kicker">— {{ section.settings.reviews_kicker | default: '7,754 reviews · 4.5 stars' }} —</div>
        <h2 class="qz-display qz-display-section">{{ section.settings.reviews_heading | default: '<p>Real members.<br><em>Real</em> catches.</p>' }}</h2>
      </div>
      <div class="qz-reviews-strip">
        {%- for r in review_blocks -%}
          <div class="qz-review-tile">
            <span class="qz-review-stars">{% assign sr = r.settings.star_rating | default: 5 %}{% for i in (1..sr) %}★{% endfor %}</span>
            <div class="qz-review-h">{{ r.settings.heading }}</div>
            <p class="qz-review-q">{{ r.settings.review }}</p>
            <div class="qz-review-name">{{ r.settings.name }}</div>
            <div class="qz-review-loc">{{ r.settings.location | default: 'MTB Subscriber' }}</div>
          </div>
        {%- endfor -%}
        {%- for r in review_blocks -%}
          <div class="qz-review-tile qz-review-tile-clone" aria-hidden="true">
            <span class="qz-review-stars">{% assign sr = r.settings.star_rating | default: 5 %}{% for i in (1..sr) %}★{% endfor %}</span>
            <div class="qz-review-h">{{ r.settings.heading }}</div>
            <p class="qz-review-q">{{ r.settings.review }}</p>
            <div class="qz-review-name">{{ r.settings.name }}</div>
            <div class="qz-review-loc">{{ r.settings.location | default: 'MTB Subscriber' }}</div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} ── What's inside ── {%- endcomment -%}
  {%- assign inside_blocks = section.blocks | where: "type", "inside_tile" -%}
  {%- if inside_blocks.size > 0 -%}
    <div class="qz-inside">
      <div class="qz-inside-inner">
        <div class="qz-inside-head">
          <div class="qz-reviews-kicker">— {{ section.settings.inside_kicker | default: "What's inside" }} —</div>
          <h2 class="qz-display qz-display-section">{{ section.settings.inside_heading | default: '<p>Full-size lures. <em>No samples.</em></p>' }}</h2>
        </div>
        <div class="qz-inside-grid">
          {%- for t in inside_blocks -%}
            {%- assign tile_color = t.settings.color | default: '#33534B' -%}
            {%- if t.settings.image != blank -%}
              <div class="qz-inside-tile qz-inside-tile-img" style="background-color: {{ tile_color }}; background-image: url({{ t.settings.image | image_url: width: 800 }});">
                <span class="qz-inside-label">{{ t.settings.label }}</span>
              </div>
            {%- else -%}
              <div class="qz-inside-tile" style="background: {{ tile_color }}">
                <span class="qz-inside-label">{{ t.settings.label }}</span>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} ── Featured brands ── {%- endcomment -%}
  {%- assign brand_blocks = section.blocks | where: "type", "brand_tile" -%}
  {%- if brand_blocks.size > 0 -%}
    <div class="qz-brands">
      <div class="qz-brands-inner">
        <h2 class="qz-display qz-display-section">{{ section.settings.brands_heading | default: 'Featured brands.' }}</h2>
        {%- if section.settings.brands_tagline != blank -%}
          <div class="qz-brands-tag">{{ section.settings.brands_tagline }}</div>
        {%- endif -%}
        <div class="qz-brands-grid">
          {%- for b in brand_blocks -%}
            <div class="qz-brand-tile">
              {%- if b.settings.logo != blank -%}
                <img src="{{ b.settings.logo | image_url: width: 240 }}" alt="{{ b.settings.name | escape }}" loading="lazy">
              {%- else -%}
                {{ b.settings.name | default: 'BRAND' }}
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      </div>
    </div>
  {%- endif -%}
</section>

{%- comment -%} ── Pricing / variant data emitted from Liquid for the JS controller ── {%- endcomment -%}
<script type="application/json" data-quiz-data="quiz-{{ section.id }}">
{
  "tiers": {
    {%- for b in product_blocks -%}
      "{{ b.id }}": {
        "name": {{ b.settings.custom_name | default: b.settings.product.title | json }},
        "items": {{ b.settings.tag_text | strip_html | strip | json }},
        "color": {{ b.settings.tier_color | default: "#33534B" | json }},
        "skill": {{ b.settings.recommendation_skill | default: "growing" | json }},
        "rec_plan": {{ b.settings.recommendation_plan | default: "6" | json }},
        "icon": {%- if b.settings.icon_image != blank -%}{{ b.settings.icon_image | image_url: width: 160 | json }}{%- else -%}null{%- endif -%},
        "images": [
          {%- assign image_keys = "image,image_2,image_3,image_4,image_5" | split: "," -%}
          {%- assign first = true -%}
          {%- for key in image_keys -%}
            {%- assign img = b.settings[key] -%}
            {%- if img != blank -%}
              {%- unless first %},{% endunless -%}{{ img | image_url: width: 1200 | json }}
              {%- assign first = false -%}
            {%- endif -%}
          {%- endfor -%}
        ],
        "default_variant_id": {%- if b.settings.product != blank -%}{{ b.settings.product.first_available_variant.id | json }}{%- else -%}null{%- endif -%},
        "plans": {
          {%- comment -%} Plan 1 (monthly) — read off the parent tier product's first variant {%- endcomment -%}
          {%- assign tier_var = b.settings.product.first_available_variant -%}
          {%- assign tier_sp_id = null -%}
          {%- if tier_var.selling_plan_allocations.size > 0 -%}
            {%- assign tier_sp_id = tier_var.selling_plan_allocations.first.selling_plan.id -%}
          {%- endif -%}
          "1": {
            "price": {{ b.settings.price | default: 0 }},
            "compare_at": {{ b.settings.compare_at_price | default: 0 }},
            "variant_id": {%- if b.settings.product != blank -%}{{ tier_var.id | json }}{%- else -%}null{%- endif -%},
            "selling_plan_id": {{ tier_sp_id | json }}
          }
          {%- for sb in sub_blocks -%}
            {%- if sb.settings.parent_product.id == b.settings.product.id -%}
              {%- assign plan_key = sb.settings.plan_key | default: "" -%}
              {%- if plan_key == "" -%}
                {%- assign txt = sb.settings.subscription_option_text | downcase -%}
                {%- if txt contains "12" -%}{%- assign plan_key = "12" -%}
                {%- elsif txt contains "6" -%}{%- assign plan_key = "6" -%}
                {%- elsif txt contains "4" -%}{%- assign plan_key = "4" -%}
                {%- else -%}{%- assign plan_key = "1" -%}{%- endif -%}
              {%- endif -%}
              {%- assign sub_var = sb.settings.product.first_available_variant -%}
              {%- assign sub_sp_id = null -%}
              {%- if sub_var.selling_plan_allocations.size > 0 -%}
                {%- assign sub_sp_id = sub_var.selling_plan_allocations.first.selling_plan.id -%}
              {%- endif -%}
              ,"{{ plan_key }}": {
                "price": {{ sb.settings.price | default: 0 }},
                "compare_at": {{ sb.settings.compare_at_price | default: 0 }},
                "variant_id": {%- if sb.settings.product != blank -%}{{ sub_var.id | json }}{%- else -%}null{%- endif -%},
                "selling_plan_id": {{ sub_sp_id | json }}
              }
            {%- endif -%}
          {%- endfor -%}
        }
      }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  },
  "default_tier": {{ default_tier_id | json }},
  "default_plan": {{ section.settings.default_plan_key | default: "6" | json }}
}
</script>

<style>
  /* ── Mystery Tackle Box brand fonts (Shopify CDN) ── */
  @font-face { font-family: "Brandon Printed"; src: url("https://cdn.shopify.com/s/files/1/0672/1794/8724/files/BrandonPrinted-One.woff?v=1777398451") format("woff"); font-weight: 400; font-style: normal; font-display: swap; }
  @font-face { font-family: "Cervo Neue"; src: url("https://cdn.shopify.com/s/files/1/0672/1794/8724/files/CervoNeue-LightNeue.otf?v=1777398457") format("opentype"); font-weight: 300; font-style: normal; font-display: swap; }
  @font-face { font-family: "Cervo Neue"; src: url("https://cdn.shopify.com/s/files/1/0672/1794/8724/files/Typoforge_Studio_-_CervoNeue-RegularNeue.otf?v=1777398457") format("opentype"); font-weight: 400; font-style: normal; font-display: swap; }
  @font-face { font-family: "Cervo Neue"; src: url("https://cdn.shopify.com/s/files/1/0672/1794/8724/files/Typoforge_Studio_-_CervoNeue-BoldNeue.otf?v=1777398457") format("opentype"); font-weight: 700; font-style: normal; font-display: swap; }
  @font-face { font-family: "Gotham SSm"; src: url("https://cdn.shopify.com/s/files/1/0672/1794/8724/files/GothamSSm-Book.woff?v=1736887231") format("woff"); font-weight: 400; font-style: normal; font-display: swap; }
