  #{{ id }} .qz-back { display: inline-flex; align-items: center; gap: 4px; margin-top: 10px; padding: 6px 14px; background: transparent; border: 1px solid rgba(16,24,32,.18); border-radius: 100px; font-family: var(--font-body); font-weight: 700; font-size: 11px; letter-spacing: 2px; text-transform: uppercase; color: rgba(16,24,32,.65); cursor: pointer; }
