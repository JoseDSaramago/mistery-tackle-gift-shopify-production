  #{{ id }}.quiz-led-pdp {
    /* Mystery Tackle Box brand palette (v2026.01) */
    --mtb-sandy-flats:   #F8F3EA;
    --mtb-green:         #33534B;
    --mtb-deep-green:    #00594F;
    --mtb-orange:        #D14424;  /* Hat Guy Orange — CTAs only */
    --mtb-weedline:      #37B777;
    --mtb-chum:          #FFCB12;
    --mtb-warm-yellow:   #FBAD18;
    --mtb-squid-ink:     #101820;
    --mtb-bait-shop:     #142648;
    --mtb-hot-sky:       #35ADE2;
    --mtb-flag-red:      #B53035;

    /* Brand typography roles */
    --font-display:   "Brandon Printed", "Archivo Black", sans-serif;
    --font-condensed: "Cervo Neue", "Oswald", "Bebas Neue", sans-serif;
    --font-body:      "Gotham SSm", system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
    --font-script:    "Zing Script Rust", "Caveat Brush", cursive;

    /* Role aliases (theme-editor-overridable defaults map to brand palette) */
    --qz-green:      {{ section.settings.brand_green  | default: '#33534B' }};
    --qz-green-dark: #1f3a33;
    --qz-gold:       {{ section.settings.brand_gold   | default: '#FBAD18' }};
    --qz-orange:     {{ section.settings.brand_orange | default: '#D14424' }};
    --qz-cream:      {{ section.settings.brand_cream  | default: '#F8F3EA' }};
    --qz-cream-alt:  #F1EAD2;
    --qz-ink:        {{ section.settings.brand_ink    | default: '#101820' }};
    --qz-yellow:     #FFCB12;
    background: var(--qz-cream);
    color: var(--qz-ink);
    font-family: var(--font-body);
  }
