<script>
(function(){
  var sectionEl = document.getElementById({{ id | json }});
  if (!sectionEl) return;
  var dataEl = document.querySelector('[data-quiz-data="quiz-{{ section.id }}"]');
  if (!dataEl) return;
  var DATA;
  try { DATA = JSON.parse(dataEl.textContent); } catch (e) { console.error('Quiz data parse error', e); return; }

  var state = {
    step: 0,
    species: null,
    speciesName: 'Bass',
    speciesColor: '#33534B',
    skill: null,
    tier: DATA.default_tier,
    plan: null,
    planUserPicked: false
  };

  var tierBySkill = {};
  Object.keys(DATA.tiers).forEach(function(tid){
    var t = DATA.tiers[tid];
    if (t.skill) tierBySkill[t.skill] = tid;
  });

  function $$(sel, root){ return Array.prototype.slice.call((root||sectionEl).querySelectorAll(sel)); }
  function $(sel, root){ return (root||sectionEl).querySelector(sel); }

  function setStep(n){
    state.step = n;
    if (n === 3) computeRecommendation();
    $$('[data-qz-step]').forEach(function(el){
      el.hidden = parseInt(el.getAttribute('data-qz-step'), 10) !== n;
    });
    var pct = Math.min(n, 3) / 3 * 100;
    var fill = $('[data-qz-progress-fill]'); if (fill) fill.style.width = pct + '%';
    var lbl = $('[data-qz-step-label]'); if (lbl) lbl.textContent = 'STEP ' + Math.min(n+1, 3) + ' OF 3';
    var back = $('[data-qz-back]'); if (back) back.hidden = n <= 0;
    if (n === 3) renderResult();
  }

  function computeRecommendation(){
    var recTier = state.skill && tierBySkill[state.skill] ? tierBySkill[state.skill] : DATA.default_tier;
    state.tier = recTier;
    if (!state.planUserPicked) state.plan = DATA.default_plan;
  }

  function planLabel(p){
    return p === '1' ? '1-month' : p + '-month';
  }

  function renderResult(){
    var t = DATA.tiers[state.tier];
    if (!t) return;
    var p = state.plan || DATA.default_plan;
    var planObj = t.plans[p] || t.plans[DATA.default_plan] || t.plans['1'];
    var months = parseInt(p, 10) || 1;

    // Gallery — render main + thumbnails for the active tier
    renderGallery(t);

    // Headline / labels
    var hl = $('[data-qz-tier-headline]');
    if (hl) hl.textContent = 'The ' + t.name;
    var sps = $('[data-qz-species-strong]');
    if (sps) { sps.textContent = state.speciesName; sps.style.color = state.speciesColor; }
    var pp = $('[data-qz-plan-prefix]');
    if (pp) pp.textContent = state.planUserPicked ? 'the' : 'our recommended';
    var pl = $('[data-qz-plan-label]');
    if (pl) pl.textContent = planLabel(p);

    // Rec card icon — image when set, otherwise first-letter fallback
    var iconWrap = $('[data-qz-rec-icon]');
    if (iconWrap) iconWrap.style.background = t.color || 'var(--qz-orange)';
    var iconLetter = $('[data-qz-rec-icon-letter]');
    var iconImg = $('[data-qz-rec-icon-img]');
    if (t.icon && iconImg) {
      iconImg.src = t.icon;
      iconImg.alt = t.name || '';
      iconImg.hidden = false;
      if (iconLetter) iconLetter.hidden = true;
    } else {
      if (iconImg) { iconImg.hidden = true; iconImg.src = ''; }
      if (iconLetter) {
        iconLetter.hidden = false;
        iconLetter.textContent = (t.name || '?').charAt(0);
      }
    }
    var rt = $('[data-qz-rec-tier]'); if (rt) rt.textContent = (t.name || '').toUpperCase();
    var ri = $('[data-qz-rec-items]'); if (ri) ri.textContent = t.items || '';
    var rp = $('[data-qz-rec-planlabel]'); if (rp) rp.textContent = planLabel(p);

    var price = (planObj.price || 0) / 100;
    var compareAt = (planObj.compare_at || 0) / 100;
    var save = Math.max(0, compareAt - price);
    var perMo = months > 0 ? (price / months) : price;

    var retailEl = $('[data-qz-rec-retail]'); if (retailEl) retailEl.textContent = compareAt > 0 ? '$' + compareAt.toFixed(2) : '';
    if (retailEl) retailEl.style.display = compareAt > 0 ? '' : 'none';
    var totalEl = $('[data-qz-rec-total]'); if (totalEl) totalEl.textContent = '$' + price.toFixed(2);
    var perMoEl = $('[data-qz-rec-permo]'); if (perMoEl) perMoEl.textContent = '$' + perMo.toFixed(2);
    var sa = $('[data-qz-save-amount]'); if (sa) sa.textContent = save.toFixed(0);
    var sav = $('[data-qz-savings]'); if (sav) sav.style.display = save > 0 ? '' : 'none';

    // Free shipping toggle (4+ months)
    var freeShip = months >= 4;
    var fs = $('[data-qz-ship-free]'); if (fs) fs.hidden = !freeShip;
    var ps = $('[data-qz-ship-paid]'); if (ps) ps.hidden = freeShip;

    // Plan button states + dynamic bottom badge
    $$('.qz-plan-btn').forEach(function(btn){
      var key = btn.getAttribute('data-qz-plan');
      btn.classList.toggle('is-active', key === p);
    });
    var bb = $('[data-qz-plan-bottom-badge]');
    if (bb) {
      // PICKED FOR YOU before any plan override, BEST after.
      bb.textContent = !state.planUserPicked ? 'PICKED FOR YOU' : 'BEST';
    }

    // Variant id + selling plan + CTA
    var vidEl = $('[data-qz-variant-id]');
    if (vidEl) vidEl.value = planObj.variant_id || t.default_variant_id || '';
    var spEl = $('[data-qz-selling-plan]');
    if (spEl) {
      if (planObj.selling_plan_id) {
        spEl.value = planObj.selling_plan_id;
        spEl.disabled = false;
      } else {
        spEl.value = '';
        spEl.disabled = true;
      }
    }
    var ctaLabel = $('[data-qz-cta-label]');
    if (ctaLabel) {
      ctaLabel.textContent = 'Start my plan' + (months > 1 ? ' · $10 OFF' : '');
    }
  }

  // Gallery — paints the main image and thumbnail rail from t.images
  function renderGallery(t){
    var thumbsEl = $('[data-qz-gallery-thumbs]');
    var mainImgEl = $('[data-qz-gallery-slot="main"]');
    if (!thumbsEl || !mainImgEl) return;

    var images = (t && t.images) ? t.images.filter(Boolean) : [];
    if (images.length === 0) {
      mainImgEl.removeAttribute('src');
      mainImgEl.alt = '';
      thumbsEl.innerHTML = '';
      return;
    }
    var name = (t && t.name) ? t.name : '';
    mainImgEl.src = images[0];
    mainImgEl.alt = name;
    thumbsEl.innerHTML = '';
    if (images.length < 2) return;
    images.forEach(function(src, i){
      var b = document.createElement('button');
      b.type = 'button';
      b.className = 'qz-gallery-thumb' + (i === 0 ? ' is-active' : '');
      b.setAttribute('role', 'tab');
      b.setAttribute('aria-label', name + ' image ' + (i + 1));
      b.setAttribute('aria-selected', i === 0 ? 'true' : 'false');
      var img = document.createElement('img');
      img.src = src;
      img.alt = '';
      img.loading = 'lazy';
      b.appendChild(img);
      b.addEventListener('click', function(){
        mainImgEl.src = src;
        mainImgEl.alt = name;
        $$('.qz-gallery-thumb', thumbsEl).forEach(function(other){
          var on = other === b;
          other.classList.toggle('is-active', on);
          other.setAttribute('aria-selected', on ? 'true' : 'false');
        });
      });
      thumbsEl.appendChild(b);
    });
  }

  // Bind step navigation
  $$('[data-qz-go]').forEach(function(btn){
    btn.addEventListener('click', function(){
      // Retake-quiz button resets all answers before re-entering step 1
      if (btn.hasAttribute('data-qz-retake')) {
        state.species = null;
        state.speciesName = 'Bass';
        state.speciesColor = '#33534B';
        state.skill = null;
        state.plan = null;
        state.planUserPicked = false;
        $$('.qz-species-tile').forEach(function(t){
          t.classList.remove('is-active');
          t.style.background = '';
          t.style.borderColor = '';
          t.style.color = '';
        });
        $$('.qz-skill-tile').forEach(function(t){ t.classList.remove('is-active'); });
      }
      setStep(parseInt(btn.getAttribute('data-qz-go'),10) || 0);
    });
  });

  // Back button — step the user one step backwards
  var backBtn = $('[data-qz-back]');
  if (backBtn) backBtn.addEventListener('click', function(){
    setStep(Math.max(0, state.step - 1));
  });

  // Species
  $$('[data-qz-species]').forEach(function(btn){
    btn.addEventListener('click', function(){
      state.species = btn.getAttribute('data-qz-species');
      state.speciesName = btn.getAttribute('data-qz-species-name') || 'Bass';
      state.speciesColor = btn.getAttribute('data-qz-species-color') || '#33534B';
      $$('.qz-species-tile').forEach(function(t){ t.classList.toggle('is-active', t === btn); });
      btn.style.background = state.speciesColor;
      btn.style.borderColor = state.speciesColor;
      btn.style.color = '#F8F3EA';
      setTimeout(function(){ setStep(2); }, 220);
    });
  });

  // Skill
  $$('[data-qz-skill]').forEach(function(btn){
    btn.addEventListener('click', function(){
      state.skill = btn.getAttribute('data-qz-skill');
      $$('.qz-skill-tile').forEach(function(t){ t.classList.toggle('is-active', t === btn); });
      setTimeout(function(){ setStep(3); }, 250);
    });
  });

  // Plan
  $$('[data-qz-plan]').forEach(function(btn){
    btn.addEventListener('click', function(){
      state.plan = btn.getAttribute('data-qz-plan');
      state.planUserPicked = true;
      renderResult();
    });
  });

  // Apply discount code on submit (Shopify accepts ?discount= on /cart redirect)
  var form = $('[data-qz-buy-form]');
  if (form) {
    form.addEventListener('submit', function(e){
      var disc = sectionEl.getAttribute('data-discount-code');
      var vid = $('[data-qz-variant-id]').value;
      if (!vid) { e.preventDefault(); console.warn('Quiz: missing variant id'); return; }
      if (disc) {
        // After /cart/add, redirect to /checkout with the discount code applied.
        var action = form.getAttribute('action') || '/cart/add';
        var sep = action.indexOf('?') === -1 ? '?' : '&';
        var returnTo = '/checkout?discount=' + encodeURIComponent(disc);
        form.setAttribute('action', action + sep + 'return_to=' + encodeURIComponent(returnTo));
      }
    });
  }

  setStep(0);
})();
</script>

