{% assign id = section.settings.custom_id | default: section.id %}

<style>
  #{{ id }} .ante-section-content {
    display: flex;
    flex-direction: row;
    gap: var(--spacing-small);
    align-items: flex-start;
    max-width: var(--width-10);
  }

  #{{ id }} .section-left {
    display: flex;
    flex-direction: column;
    width: calc(50% - var(--spacing-small) / 2);
    position: sticky;
    top: var(--sticky-top);
    transition: top .25s;
    gap: var(--spacing-x-small);
  }

  @media (max-height: 1100px) {
    #{{ id }} .section-left {
      max-width: 720px;
    }
  }

  @media (max-height: 930px) {
    #{{ id }} .section-left {
      max-width: 600px;
    }
  }

  #{{ id }} .section-info {
    display: grid;
    grid-auto-flow: column;
    grid-template-rows: repeat(3, auto);
    column-gap: var(--spacing-small);
    row-gap: var(--micropad-medium);
    text-align: center;
  }

  @media (min-width: 601px) {
    #{{ id }} .section-info {
      margin-top: calc(var(--spacing-medium) * -1);
      padding-top: var(--spacing-x-small);
    }
  }

  #{{ id }} .section-right {
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: var(--spacing-medium);
  }

  #{{ id }} .section-right-top {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-x-small);
  }

  #{{ id }} .section-right-header {
    display: flex;
    flex-direction: column;
    gap: var(--micropad-x-large);
  }

  #{{ id }} h2 {
    text-align: center;
  }

  #{{ id }} .step-container {
    background-color: var(--color-surface-100);
    border: 1px solid var(--color-border);
    padding: var(--padding-large);
    border-radius: var(--radius-large);
  }

  #{{ id }} .step-steps {
    display: flex;
    gap: var(--micropad-x-large);
  }

  #{{ id }} .step-step {
    flex: 1;
    text-align: center;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-bottom: var(--micropad-large);
    gap: var(--micropad-x-small);
    font-style: italic;
    user-select: none;
    pointer-events: none;
  }

  #{{ id }} .step-step h6 {
    height: 24px;
    display: flex;
    align-items: center;
    line-height: 1;
  }

  #{{ id }} .step-step.active ~ .step-step h6,
  #{{ id }} .step-step.active ~ .step-step::after {
    opacity: 0.4;
  }

  #{{ id }} .step-step svg {
    display: none;
    width: 24px;
    height: 24px;
    margin-left: var(--micropad-x-small);
  }

  #{{ id }} .step-step path {
    color: #6DB129;
  }

  #{{ id }} .step-step:has(~ .active) {
    cursor: pointer;
    pointer-events: initial;
  }

  #{{ id }} .step-step:has(~ .active) svg {
    display: initial;
  }

  #{{ id }} .step-step::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    border-radius: 10px;
    background-color: var(--color-button);
  }

  #{{ id }} .step-wrapper {
    display: flex;
    margin: var(--spacing-medium) 0 var(--spacing-x-small);
  }

  #{{ id }} .step {
    flex-direction: column;
    gap: var(--spacing-x-small);
    width: 100%;
    display: none;
  }

  #{{ id }} .step.active {
    display: flex;
  }

  #{{ id }} .step input {
    display: none;
  }

  #{{ id }} .step label {
    display: flex;
    background-color: var(--color-surface-100);
    border: 1px solid var(--color-border);
    cursor: pointer;
    user-select: none;
    position: relative;
    transition: background-color .15s, border .15s;
    padding: var(--padding-medium);
    gap: var(--micropad-x-large);
    border-radius: var(--radius-medium);
    width: 100%;
  }

  #{{ id }} .step label.has-input-tag {
    margin-top: calc(var(--spacing-x-small) * -1);
    border-top-left-radius: 0;
  }

  #{{ id }} .step label.best-value::before {
    content: "Best Value";
  }

  #{{ id }} .step2 img {
    border-radius: 50%;
    border: 1px solid var(--color-border);
    transition: border .15s;
  }

  #{{ id }} .step2 input:checked + label img {
    border: 1px solid var(--color-text-default);
  }

  #{{ id }} .input-left {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--micropad-x-large);
    justify-content: center;
  }

  #{{ id }} .input-row {
    display: flex;
    align-items: center;
    width: 100%;
  }

  #{{ id }} .input-row > * {
    order: 1;
  }

  #{{ id }} .input-row::before {
    content: "";
    min-width: 22px;
    height: 22px;
    border: 2px solid var(--color-text-default);
    border-radius: 50%;
    transition: border .15s;
    order: 0;
  }

  #{{ id }} .input-row::after {
    content: "";
    min-width: 10px;
    height: 10px;
    border-radius: 50%;
    transition: background-color .15s, scale .15s;
    order: 0;
    scale: 0;
    margin-left: -16px;
    margin-right: calc(5px + var(--micropad-medium));
  }

  #{{ id }} .input-name {
    margin-right: var(--micropad-x-large);
  }

  #{{ id }} .input-row > .ante-price {
    flex: 1;
  }

  #{{ id }} .step input:checked + label {
    background-color: var(--inverse-color-background);
    border: 1px solid var(--color-text-default);
  }

  #{{ id }} .step input:checked + label * {
    color: var(--inverse-color-text-default);
  }

  #{{ id }} .step input:checked + label .input-row::before {
    border: 2px solid var(--inverse-color-text-alt);
  }

  #{{ id }} .step input:checked + label .input-row::after {
    background-color: var(--inverse-color-text-alt);
    scale: 1;
  }

  #{{ id }} .input-facts {
    display: flex;
    gap: var(--micropad-x-large);
  }

  #{{ id }} .input-facts .fact {
    display: flex;
    align-items: center;
    gap: var(--micropad-x-small);
  }

  #{{ id }} .input-facts svg {
    color: var(--color-text-default);
  }

  #{{ id }} .step-buttons {
    display: flex;
    gap: var(--micropad-x-large);
    align-items: flex-start;
  }

  #{{ id }} .step-buttons > :last-child {
    flex: 1;
  }

  #{{ id }} .back-button svg {
    rotate: 180deg;
  }

  #{{ id }} .step-description {
    align-items: center;
    border-bottom: 1px dashed var(--color-text-default);
    justify-content: space-between;
    padding-bottom: var(--spacing-x-small);
    margin-bottom: var(--spacing-x-small);
  }

  #{{ id }} .modal-button {
    cursor: pointer;
    display: inline-flex;
    color: var(--color-background-alt);
  }

  #{{ id }} .step-description .modal-button {
    transform: translateY(3px);
  }

  #{{ id }} .step-delivered {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--micropad-medium);
  }

  #{{ id }} .step-delivered-count {
    display: flex;
    align-items: center;
    gap: 2px;
    font-family: "Brandon Grotesque", helvetica;
    font-size: 17.462px;
    font-weight: 900;
    color: var(--color-text-muted);
  }

  #{{ id }} .step-delivered-count > div {
    border: 1px solid var(--color-text-default);
    height: 20px;
    width: 15px;
    border-radius: 3.629px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #{{ id }} .step-header-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  #{{ id }} .section-media {
    display: flex;
    gap: var(--spacing-x-small);
    align-items: center;
  }

  #{{ id }} .section-media > :last-child {
    display: flex;
    flex-direction: column;
    gap: var(--micropad-x-large);
  }

  #{{ id }} .section-media .ante-image {
    min-width: 146px;
    border-radius: var(--radius-large);
  }

  #{{ id }} .starting-from {
    display: flex;
    justify-content: center;
    align-items: flex-end;
    gap: var(--micropad-x-small);
  }

  #{{ id }} .save-big {
    display: flex;
    justify-content: center;
    align-items: center;
    background-color: var(--color-sale);
    align-self: center;
    padding: var(--padding-tab);
    gap: 4px;
    border-radius: var(--radius-large);
  }

  #{{ id }} .save-big.section-desktop {
    margin-bottom: var(--spacing-x-small);
  }

  #{{ id }} .save-big-icon {
    height: 0;
    display: flex;
    align-items: center;
  }

  #{{ id }} .save-big-icon svg {
    width: 90px;
    height: 94px;
    margin: 0 -10px;
    transform: translateY(-3px);
  }

  #{{ id }} .save-big > :nth-child(2) {
    color: var(--color-button);
  }

  #{{ id }} .review-stars {
    justify-content: center;
  }

  #{{ id }} .input-content-row {
    display: flex;
    gap: var(--spacing-x-small);
  }

  #{{ id }} .input-content-row .input-image {
    align-self: flex-end;
  }

  #{{ id }} .input-content-row-left {
    display: flex;
    flex-direction: column;
    gap: var(--micropad-medium);
    flex: 1;
    justify-content: center;
  }

  #{{ id }} .info-message {
    text-align: center;
  }

  #{{ id }} .section-mobile,
  #{{ id }} .step-mobile {
    display: none;
  }

  @media (max-width: 1300px) {
    #{{ id }} .step-desktop {
      display: none;
    }

    #{{ id }} .step-mobile {
      display: flex;
    }

    #{{ id }} .step-mobile .input-name {
      flex: 1;
    }

    #{{ id }} .step-mobile .input-facts {
      flex-direction: column;
      gap: var(--micropad-x-small);
    }
  }

  @media (max-width: 1919px) {
    #{{ id }} .ante-section-content {
      max-width: 100%;
    }
  }

  @media (max-width: 1024px) {
    #{{ id }} .ante-section-content {
      flex-direction: column;
      align-items: stretch;
      gap: var(--spacing-medium);
    }

    #{{ id }} .ante-section-content > div {
      display: contents !important;
    }

    #{{ id }} .ante-section-content > div > * {
      order: 10;
    }

    #{{ id }} .section-right-top {
      order: 0 !important;
    }

    #{{ id }} .section-right > *:not(.section-right-top) {
      max-width: var(--width-6);
      margin: 0 auto;
    }

    #{{ id }} .section-desktop {
      display: none;
    }

    #{{ id }} .section-mobile {
      display: flex;
    }

    #{{ id }} .step-desktop {
      display: flex;
    }

    #{{ id }} .step-mobile {
      display: none;
    }
  }

  @media (max-width: 600px) {
    #{{ id }} .section-right > * {
      width: 100%;
      max-width: 100% !important;
    }

    #{{ id }} .step label {
      padding: var(--padding-small);
    }

    #{{ id }} .input-left {
      gap: var(--micropad-large);
    }

    #{{ id }} .step-buttons {
      flex-direction: column-reverse;
      align-items: stretch;
    }

    #{{ id }} .save-big-icon svg {
      width: 80px;
      height: 84px;
    }

    #{{ id }} .step-delivered {
      flex-direction: column;
      gap: var(--micropad-x-small);
    }
  }

  @media (max-width: 580px) {
    #{{ id }} .step-desktop {
      display: none;
    }

    #{{ id }} .step-mobile {
      display: flex;
    }
  }
</style>

{% for block in section.blocks %}
  {% if block.type == "product" and block.settings.product %}
    {% assign first_price = block.settings.product.variants.first.price %}
    {% if block.settings.use_custom_price %}
      {% assign first_price = block.settings.custom_price %}
    {% else %}
      {% assign first_price = block.settings.product.variants.first.price %}
    {% endif %}
    {% if block.settings.use_custom_price %}
      {% assign first_compare_price = block.settings.custom_compare_at_price %}
    {% else %}
      {% assign first_compare_price = block.settings.product.variants.first.compare_at_price | default: 0 %}
    {% endif %}
    {% break %}
  {% endif %}
{% endfor %}

{% render "ante-section-structure", section: section %}
  <div class="section-left">
    {% assign final_urls = "" %}

    {% for block in section.blocks %}
      {% if block.type == "image" and block.settings.position == "before" %}
        {% assign url = block.settings.image | image_url: width: 1024 %}
        {% assign final_urls = final_urls | append: url | append: "|||" %}
      {% endif %}
    {% endfor %}

    {% if section.settings.carousel_product %}
      {% for image in section.settings.carousel_product.images %}
        {% assign url = image | image_url: width: 1024 %}
        {% assign final_urls = final_urls | append: url | append: "|||" %}
      {% endfor %}
    {% endif %}

    {% for block in section.blocks %}
      {% if block.type == "image" and block.settings.position == "after" %}
        {% assign url = block.settings.image | image_url: width: 1024 %}
        {% assign final_urls = final_urls | append: url | append: "|||" %}
      {% endif %}
    {% endfor %}

    {% assign final_urls = final_urls | split: "|||" | compact %}
    
    {% render "ante-image-carousel", images: final_urls, id: id %}
  </div>
  <div class="section-right">
    <div class="section-right-top">
      <div class="section-right-header">
        {% render "ante-stars", rating: section.settings.star_rating, count: section.settings.star_review_count, link: section.settings.star_link %}
        <h2>{{ section.settings.custom_heading }}</h2>
      </div>
      <div class="starting-from">
        <span class="body-caption alt">Starting from</span>
        {% render "ante-price", static: true, big: true, price: first_price, compare_price: first_compare_price %}
      </div>
      <div class="save-big section-mobile">
        <div class="save-big-icon">
          {% render "ante-svg", icon: "face-wow" %}
        </div>
        <h6>SAVE BIG</h6>
        <span class="body-caption alt">on select plans only</span>
      </div>
    </div>
    <div class="section-info">
      {% for block in section.blocks %}
        {% if block.type == "info" %}
          {% render "ante-image", image: block.settings.image, height: 80 %}
          <h6>{{ block.settings.text }}</h6>
          <div class="body-caption muted">{{ block.settings.description }}</div>
        {% endif %}
      {% endfor %}
    </div>
    <div class="step-container">
      <div class="save-big section-desktop">
        <div class="save-big-icon">
          {% render "ante-svg", icon: "face-wow" %}
        </div>
        <h6>SAVE BIG</h6>
        <span class="body-caption alt">on select plans only</span>
      </div>
      <div class="step-description">
        <span class="body-base bold">{{ section.settings.steps_description }}</span>
        {% if section.settings.steps_description_modal_content != blank %}
          <div class="step-description-modal-button modal-button">
            {% render "ante-svg", icon: "info" %}
          </div>
          <div class="modal" data-title="{{ section.settings.steps_description_modal_title }}" data-trigger="step-description-modal-button">
            <div class="richtext">{{ section.settings.steps_description_modal_content }}</div>
          </div>
        {% endif %}
      </div>
      <div class="step-steps">
        <div class="step-step step1-step active"><h6>STEP 1</h6> {% render "ante-svg", icon: "check" %}</div>
        <div class="step-step step2-step"><h6>STEP 2</h6> {% render "ante-svg", icon: "check" %}</div>
        <div class="step-step step3-step"><h6>STEP 3</h6> {% render "ante-svg", icon: "check" %}</div>
      </div>
      <div class="step-wrapper">
        <div class="step step1 active">
          <div class="step-header-row">
            <h5 class="step-header">{{ section.settings.step_1_heading }}</h5>
            {% if section.settings.step_1_info != blank %}
              <div class="step1-modal-button modal-button">
                {% render "ante-svg", icon: "info" %}
              </div>
              <div class="modal" data-title="{{ section.settings.step_1_info_title }}" data-trigger="step1-modal-button">
                <div class="richtext">{{ section.settings.step_1_info }}</div>
              </div>
            {% endif %}
          </div>
          {% for block in section.blocks %}
            {% if block.type == "product" and block.settings.product %}
              {% if block.settings.outer_tag_text != blank %}
                <div class="ante-outer-tag">{{ block.settings.outer_tag_text }}</div>
              {% endif %}
              <input type="radio" name="step1" id="product-{{ block.settings.product.id }}" data-product="{{ block.settings.product.id }}"{% if block.settings.preselected %} checked{% endif %}>
              <label for="product-{{ block.settings.product.id }}" class="product{% if block.settings.outer_tag_text != blank %} has-input-tag{% endif %}">
                {% assign image = block.settings.custom_image | default: block.settings.product.featured_image %}
                <div class="input-left step-desktop">
                  <div class="input-row">
                    <h6 class="input-name">{{ block.settings.custom_title | default: block.settings.product.title }}</h6>
                    {% assign price = block.settings.product.variants.first.price %}
                    {% assign compare_price = block.settings.product.variants.first.compare_at_price %}
                    {% if block.settings.use_custom_price %}
                      {% assign price = block.settings.custom_price %}
                    {% endif %}
                    {% if block.settings.use_custom_compare_at_price %}
                      {% assign compare_price = block.settings.custom_compare_at_price %}
                    {% endif %}
                    {% render "ante-price", static: true, price: price, compare_price: compare_price %}
                    {% if block.settings.inner_tag_text != blank %}
                      <div class="ante-inner-tag">{{ block.settings.inner_tag_text }}</div>
                    {% endif %}
                  </div>
                  <div class="input-facts">
                    {% assign facts = block.settings.facts | newline_to_br | split: '<br />' %}
                    {% for fact in facts %}
                      {% assign trimmed_fact = fact | strip %}
                      {% if trimmed_fact != blank %}
                        <div class="fact body-caption muted">{% render "ante-svg", icon: "check" %} {{ trimmed_fact }}</div>
                      {% endif %}
                    {% endfor %}
                  </div>
                </div>
                <div class="input-left step-mobile">
                  <div class="input-row">
                    <h6 class="input-name">{{ block.settings.custom_title | default: block.settings.product.title }}</h6>
                    {% if block.settings.inner_tag_text != blank %}
                      <div class="ante-inner-tag">{{ block.settings.inner_tag_text }}</div>
                    {% endif %}
                  </div>
                  <div class="input-content-row">
                    <div class="input-content-row-left">
                      {% assign price = block.settings.product.variants.first.price %}
                      {% assign compare_price = block.settings.product.variants.first.compare_at_price %}
                      {% if block.settings.use_custom_price %}
                        {% assign price = block.settings.custom_price %}
                      {% endif %}
                      {% if block.settings.use_custom_compare_at_price %}
                        {% assign compare_price = block.settings.custom_compare_at_price %}
                      {% endif %}
                      {% render "ante-price", static: true, price: price, compare_price: compare_price %}
                      <div class="input-facts">
                        {% assign facts = block.settings.facts | newline_to_br | split: '<br />' %}
                        {% for fact in facts %}
                          {% assign trimmed_fact = fact | strip %}
                          {% if trimmed_fact != blank %}
                            <div class="fact body-caption muted">{% render "ante-svg", icon: "check" %} {{ trimmed_fact }}</div>
                          {% endif %}
                        {% endfor %}
                      </div>
                    </div>
                    <div class="input-image">
                      {% render "ante-image", image: image, height: 64 %}
                    </div>
                  </div>
                </div>
                <div class="input-image step-desktop">
                  {% render "ante-image", image: image, height: 64 %}
                </div>
              </label>
            {% endif %}
          {% endfor %}
          <button class="ante-button step1-next-button" disabled>{{ section.settings.step_1_button_text }} {% render "ante-svg", icon: "arrow" %}</button>
        </div>
        {% if section.settings.step_2_info != blank %}
          <div class="modal" data-title="{{ section.settings.step_2_info_title }}" data-trigger="step2-modal-button">
            <div class="richtext">{{ section.settings.step_2_info }}</div>
          </div>
        {% endif %}
        {% if section.settings.step_3_info != blank %}
          <div class="modal" data-title="{{ section.settings.step_3_info_title }}" data-trigger="step3-modal-button">
            <div class="richtext">{{ section.settings.step_3_info }}</div>
          </div>
        {% endif %}
        {% for block in section.blocks %}
          {% if block.type == "product" and block.settings.product %}
            <div class="step step2" data-product="{{ block.settings.product.id }}" hidden>
              <div class="step-header-row">
                <h5 class="step-header">{{ section.settings.step_2_heading }}</h5>
                {% if section.settings.step_2_info != blank %}
                  <div class="step2-modal-button modal-button">
                    {% render "ante-svg", icon: "info" %}
                  </div>
                {% endif %}
              </div>
              {% for variant in block.settings.product.variants %}
                {% if variant.metafields.ante.variant_tag_text != blank %}
                  <div class="ante-outer-tag">{{ variant.metafields.ante.variant_tag_text }}</div>
                {% endif %}
                <input type="radio" name="variants-{{ block.settings.product.id }}" id="product-variant-{{ variant.id }}" data-index="{{ forloop.index0 }}" {% if variant.metafields.ante.variant_preselected %} checked{% endif %}>
                <label for="product-variant-{{ variant.id }}" class="product{% if variant.metafields.ante.variant_tag_text != blank %} has-input-tag{% endif %}">
                  <div class="input-left">
                    <div class="input-row">
                      <h6 class="input-name">{{ variant.title }}</h6>
                    </div>
                    {% if variant.metafields.ante.variant_description != blank %}
                      <div class="input-description body-caption">{{ variant.metafields.ante.variant_description }}</div>
                    {%endif %}
                  </div>
                  <div class="input-image">
                    {% assign image = variant.metafields.ante.variant_image | default: variant.image | default: block.settings.product.featured_image %}
                    {% render "ante-image", image: image, height: 64 %}
                  </div>
                </label>
              {% endfor %}
              <div class="step-buttons">
                <button class="ante-button flat back-button step2-back-button">{% render "ante-svg", icon: "arrow" %} BACK</button>
                <button class="ante-button step2-next-button" disabled>{{ section.settings.step_2_button_text }} {% render "ante-svg", icon: "arrow" %}</button>
              </div>
            </div>
            <div class="step step3" data-product="{{ block.settings.product.id }}" hidden>
              <div class="step-header-row">
                <h5 class="step-header">{{ section.settings.step_3_heading }}</h5>
                {% if section.settings.step_3_info != blank %}
                  <div class="step3-modal-button modal-button">
                    {% render "ante-svg", icon: "info" %}
                  </div>
                {% endif %}
              </div>
              {% if block.settings.outer_tag_text_step3 != blank %}
                <div class="ante-outer-tag">{{ block.settings.outer_tag_text_step3 }}</div>
              {% endif %}
