<script type="module">
  window.addEventListener("pageshow", e => {
    document.querySelectorAll("#{{ id }} .step1 input[type='radio']:checked").forEach(input => {
      input.dispatchEvent(new Event("change", { bubbles: true }))
    })
  })

  const prices = document.querySelectorAll(".ante-buy-price")
  const comparePrices = document.querySelectorAll(".ante-buy-compare-price")

  setPrice({{ first_price }}, {{ first_compare_price }})

  const step1Inputs = document.querySelectorAll("#{{ id }} input[name='step1']")
  const productSteps = document.querySelectorAll("#{{ id }} .step[data-product]")

  step1Inputs.forEach(input => input.addEventListener("change", evt => {
    productSteps.forEach(e => e.hidden = e.dataset.product !== input.dataset.product)
  }))

  const stepSteps = document.querySelectorAll("#{{ id }} .step-step")
  const step1Step = document.querySelector("#{{ id }} .step1-step")
  const step2Step = document.querySelector("#{{ id }} .step2-step")
  const step3Step = document.querySelector("#{{ id }} .step3-step")
  const steps = document.querySelectorAll("#{{ id }} .step")
  const step1 = document.querySelector("#{{ id }} .step1")
  const step2 = document.querySelectorAll("#{{ id }} .step2")
  const step3 = document.querySelectorAll("#{{ id }} .step3")

  let activeStep = 1

  function clean() {
    document.querySelector("#{{ id }} .step.active:not([hidden])").querySelector("input:checked").dispatchEvent(new Event("change", { bubbles: true }))
    stepSteps.forEach(e => e.classList.remove("active"))
    steps.forEach(e => e.classList.remove("active"))
    smoothScroll(document.querySelector("#{{ id }} .step-container"))
    setTimeout(() => {
      document.querySelector("#{{ id }} .step.active:not([hidden])").querySelector("input:checked").dispatchEvent(new Event("change", { bubbles: true }))
    }, 0)
  }

  function activateStep1() {
    activeStep = 1
    clean()
    step1Step.classList.add("active")
    step1.classList.add("active")
  }

  function activateStep2() {
    activeStep = 2
    clean()
    step2Step.classList.add("active")
    step2.forEach(e => e.classList.add("active"))
  }

  function activateStep3() {
    activeStep = 3
    clean()
    step3Step.classList.add("active")
    step3.forEach(e => e.classList.add("active"))
  }

  document.querySelector("#{{ id }} .step1-next-button").addEventListener("click", activateStep2)
  document.querySelector("#{{ id }} .step1-step").addEventListener("click", activateStep1)
  document.querySelector("#{{ id }} .step2-step").addEventListener("click", e => {
    if (document.querySelector("#{{ id }} .step3-step").classList.contains("active")) {
      activateStep2()
    }
  })
  document.querySelectorAll("#{{ id }} .step2-back-button").forEach(e => e.addEventListener("click", activateStep1))
  document.querySelectorAll("#{{ id }} .step2-next-button").forEach(e => e.addEventListener("click", activateStep3))
  document.querySelectorAll("#{{ id }} .step3-back-button").forEach(e => e.addEventListener("click", activateStep2))

  const products = {
    {% for block in section.blocks %}
      {% if block.type == "product" and block.settings.product %}
        "{{ block.settings.product.id }}": {
          "{{ block.settings.product.id }}": {
            sellingPlan: {{ block.settings.product.selling_plan_groups.first.selling_plans.first.id }},
            variants: [
              {% for variant in block.settings.product.variants %}
                {
                  id: {{ variant.id }},
                  {% if block.settings.use_custom_price %}
                    price: {{ block.settings.custom_price }},
                  {% else %}
                    price: {{ variant.price }},
                  {% endif %}
                  {% if block.settings.use_custom_compare_at_price %}
                    comparePrice: {{ block.settings.custom_compare_at_price }}
                  {% else %}
                    comparePrice: {{ variant.compare_at_price | default: 0 }}
                  {% endif %}
                },
              {% endfor %}
            ],
            infoMessage: "{{ block.settings.info_message }}"
          },
          {% for subblock in section.blocks %}
            {% if subblock.type == "product_frequency_option" and subblock.settings.parent_product.id == block.settings.product.id and subblock.settings.frequency_product %}
              "{{ subblock.settings.frequency_product.id }}": {
                sellingPlan: {{ subblock.settings.frequency_product.selling_plan_groups.first.selling_plans.first.id }},
                variants: [
                  {% for variant in subblock.settings.frequency_product.variants %}
                    {
                      id: {{ variant.id }},
                      {% if subblock.settings.use_custom_price %}
                        price: {{ subblock.settings.custom_price }},
                      {% else %}
                        price: {{ variant.price }},
                      {% endif %}
                      {% if subblock.settings.use_custom_compare_at_price %}
                        comparePrice: {{ subblock.settings.custom_compare_at_price }},
                      {% else %}
                        comparePrice: {{ variant.compare_at_price | default: 0 }},
                      {% endif %}
                      {% if subblock.settings.frequency_duration %}
                        duration: "{{ subblock.settings.frequency_duration }}"
                      {% endif %}
                    },
                  {% endfor %}
                ],
                infoMessage: "{{ subblock.settings.info_message }}"
              },
            {% endif %}
          {% endfor %}
        },
      {% endif %}
    {% endfor %}
  }

  let selectedStep1, variantIndex, frequency

  const infoMessages = document.querySelectorAll("#{{ id }} .step .info-message")

  document.querySelectorAll("#{{ id }} .step input").forEach(e => e.addEventListener("change", evt => {
    e.parentElement.querySelector(".ante-button:not(.back-button)").disabled = false
    const name = e.getAttribute("name")
    let product, variant
    if (name === "step1") {
      selectedStep1 = e.dataset.product
      product = products[selectedStep1][selectedStep1]
      variant = product.variants[0]
    } else if (name.startsWith("variants")) {
      variantIndex = e.dataset.index
      product = products[selectedStep1][selectedStep1]
      variant = product.variants[variantIndex]
    } else if (name.startsWith("frequency")) {
      frequency = e.dataset.product
      product = products[selectedStep1][frequency]
      variant = product.variants[variantIndex]
    }
    for (const infoMessage of infoMessages) {
      if (product.infoMessage && name.startsWith("frequency")) {
        infoMessage.textContent = product.infoMessage
        infoMessage.hidden = false
      } else {
        infoMessage.hidden = true
      }
    }
    setPrice(variant.price, variant.comparePrice, variant.duration)
  }))

  document.querySelectorAll("#{{ id }} .ante-buy-button").forEach(input => input.addEventListener("click", async evt => {
    input.loading = true
    await fetch("/cart/clear")

    const r = await fetch("/cart/add.js", {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({
        id: products[selectedStep1][frequency].variants[variantIndex].id,
        quantity: 1,
        selling_plan: products[selectedStep1][frequency].sellingPlan,
        properties: {
          _from_multi_step_variants: true
        }
      })
    })
    
    if (!r.ok) {
      input.loading = false
      throw `Failed to add to cart: ${await r.text()}`
    }

    {% if section.settings.discount_code %}
      await fetch("/discount/{{ section.settings.discount_code }}")
    {% endif %}

    input.loading = false

    location = "/checkout"
  }))

  document.querySelectorAll(".ante-buy-button").forEach((button, i) => button.addEventListener("click", e => {
    if (!button.closest("#{{ id }}")) {
      smoothScroll(document.querySelector("#{{ id }} .step-container"))
    }
  }))
</script>

