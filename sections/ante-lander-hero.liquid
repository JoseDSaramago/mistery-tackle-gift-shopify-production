              { "value": "none", "label": "None" },
              { "value": "spacing-large", "label": "Spacing Large" },
              { "value": "spacing-medium", "label": "Spacing Medium" },
              { "value": "spacing-small", "label": "Spacing Small" },
              { "value": "spacing-x-small", "label": "Spacing X-Small" },
              { "value": "padding-x-large", "label": "Padding X-Large" },
              { "value": "padding-large", "label": "Padding Large" },
              { "value": "padding-medium", "label": "Padding Medium" },
              { "value": "padding-small", "label": "Padding Small" },
              { "value": "micropad-x-large", "label": "Micropad X-Large" },
              { "value": "micropad-large", "label": "Micropad Large" },
              { "value": "micropad-medium", "label": "Micropad Medium" },
              { "value": "micropad-small", "label": "Micropad Small" },
              { "value": "micropad-x-small", "label": "Micropad X-Small" }
            ],
            "default": "none",
            "info": "A gap to have below this block"
          },
          {
            "type": "select",
            "id": "show_on",
            "label": "Show on",
            "options": [
              { "value": "desktop", "label": "Desktop" },
              { "value": "desktop-tablet", "label": "Desktop & Tablet" },
              { "value": "tablet", "label": "Tablet" },
