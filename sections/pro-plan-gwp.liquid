<script>
  (function () {
    var root = document.getElementById({{ id | json }});
    if (!root) return;

    // ── Strip width constraints off every ancestor between our section and
    //    <body>, so the full-bleed children can actually reach the viewport
    //    edges. Theme CSS often wraps the section in a fixed-width container;
    //    this neutralizes that without us needing to know the wrapper class. ──
    (function clearAncestorConstraints() {
      var node = root.parentElement;
      while (node && node !== document.body && node !== document.documentElement) {
        node.style.setProperty('max-width', 'none',     'important');
        node.style.setProperty('width',     '100%',     'important');
        node.style.setProperty('margin-left',  '0',     'important');
        node.style.setProperty('margin-right', '0',     'important');
        node.style.setProperty('padding-left', '0',     'important');
        node.style.setProperty('padding-right','0',     'important');
        node.style.setProperty('overflow-x',   'visible','important');
        node = node.parentElement;
      }
    })();

    // ── Gallery: thumbs swap main image ──
    var mainImg     = root.querySelector('[data-lp-buy-main]');
    var thumbsList  = root.querySelector('[data-lp-thumbs]');

    function wireThumb(t) {
      t.addEventListener('click', function () {
        thumbsList.querySelectorAll('[data-lp-thumb]').forEach(function (x) { x.classList.remove('is-active'); });
        t.classList.add('is-active');
        var src = t.getAttribute('data-lp-thumb-src');
        var alt = t.getAttribute('data-lp-thumb-alt') || '';
        if (mainImg && src && mainImg.tagName === 'IMG') {
          mainImg.src = src;
          mainImg.alt = alt;
        }
      });
    }
    if (thumbsList) {
      thumbsList.querySelectorAll('[data-lp-thumb]').forEach(wireThumb);
    }

    // ── Rebuild the gallery (main image + thumbnails) for a chosen species ──
    function paintGallery(srcs, alts) {
      if (!mainImg || !thumbsList) return;
      if (!srcs || srcs.length === 0) return;
      // Swap main image
      if (mainImg.tagName !== 'IMG') {
        // Replace placeholder div with img
        var img = document.createElement('img');
        img.className = 'lp-buy__main-img';
        img.setAttribute('data-lp-buy-main', '');
        img.loading = 'lazy';
        mainImg.parentNode.replaceChild(img, mainImg);
        mainImg = img;
      }
      mainImg.src = srcs[0];
      mainImg.alt = alts[0] || '';
      // Rebuild thumbnails
      thumbsList.innerHTML = '';
      srcs.forEach(function (src, i) {
        var btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'lp-buy__thumb' + (i === 0 ? ' is-active' : '');
        btn.setAttribute('data-lp-thumb', '');
        btn.setAttribute('data-lp-thumb-src', src);
        btn.setAttribute('data-lp-thumb-alt', alts[i] || '');
        btn.setAttribute('aria-label', 'View photo ' + (i + 1));
        var im = document.createElement('img');
        im.src = src;
        im.alt = '';
        im.loading = 'lazy';
        btn.appendChild(im);
        wireThumb(btn);
        thumbsList.appendChild(btn);
      });
    }

    // ── Species selection ──
    var speciesBtns = root.querySelectorAll('[data-lp-species]');
    var cartSpecies = root.querySelector('[data-lp-cart-species]');
    function setSpecies(btn) {
      speciesBtns.forEach(function (b) { b.classList.remove('is-active'); });
      btn.classList.add('is-active');
      if (cartSpecies) cartSpecies.value = btn.getAttribute('data-lp-species-name') || '';

      // Swap the gallery to this species' images (if it has any)
      var imgsAttr = btn.getAttribute('data-lp-species-imgs') || '';
      var altsAttr = btn.getAttribute('data-lp-species-alts') || '';
      var srcs = imgsAttr.split('|').filter(function (s) { return s.length > 0; });
      var alts = altsAttr.split('|');
      if (srcs.length > 0) paintGallery(srcs, alts);
    }
    speciesBtns.forEach(function (b) {
      b.addEventListener('click', function () { setSpecies(b); });
    });
    // initialize species line-item value + gallery from preselected
    var activeSpecies = root.querySelector('[data-lp-species].is-active');
    if (activeSpecies) setSpecies(activeSpecies);

    // ── Cadence selection ──
    var cadBtns          = root.querySelectorAll('[data-lp-cadence]');
    var cartVariant      = root.querySelector('[data-lp-cart-variant]');
    var cartSellingPlan  = root.querySelector('[data-lp-cart-selling-plan]');
    var ctaLabel         = root.querySelector('[data-lp-cta-label]');
    // IMPORTANT: scope gift-card queries to the gift card container.
    // Cadence buttons also carry data-lp-gift-* attributes (for storage of
    // their gift info), so a root-level querySelector would match the FIRST
    // cadence button instead of the gift card and overwrite its DOM.
    var giftCard         = root.querySelector('[data-lp-gift-card]');
    var giftCardName     = giftCard && giftCard.querySelector('[data-lp-gift-name]');
    var giftCardNote     = giftCard && giftCard.querySelector('[data-lp-gift-note]');
    var giftCardTag      = giftCard && giftCard.querySelector('[data-lp-gift-tag]');
    var giftCardThmb     = giftCard && giftCard.querySelector('[data-lp-gift-thumb]');
    var baseCta          = {{ section.settings.buy_cta_template | default: 'Start My Plan' | json }};

    function setCadence(btn) {
      cadBtns.forEach(function (b) {
        b.classList.remove('is-active');
        b.setAttribute('aria-checked', 'false');
      });
      btn.classList.add('is-active');
      btn.setAttribute('aria-checked', 'true');

      if (cartVariant)  cartVariant.value = btn.getAttribute('data-lp-variant-id') || '';

      // Selling plan: subscription variants require this — disable the input
      // when there's no plan so Shopify doesn't choke on an empty value.
      var sp = btn.getAttribute('data-lp-selling-plan') || '';
      if (cartSellingPlan) {
        if (sp) {
          cartSellingPlan.value = sp;
          cartSellingPlan.disabled = false;
        } else {
          cartSellingPlan.value = '';
          cartSellingPlan.disabled = true;
        }
      }

      var ship = btn.getAttribute('data-lp-ship') || '';
      if (ctaLabel) ctaLabel.textContent = ship ? (baseCta + ' · ' + ship + '/box') : baseCta;

      var gName = (btn.getAttribute('data-lp-gift-name') || '').trim();
      var gTag  = (btn.getAttribute('data-lp-gift-tag')  || '').trim();
      var gNote = (btn.getAttribute('data-lp-gift-note') || '').trim();
      var gImg  = btn.getAttribute('data-lp-gift-image') || '';

      // If this cadence has no gift attached, hide the entire green
      // "FREE GIFT UNLOCKED" callout above the CTA. Otherwise show it
      // and update its contents from the cadence's data attrs.
      var hasGift = !!(gName || gTag || gNote);
      if (giftCard) giftCard.style.display = hasGift ? '' : 'none';

      if (hasGift) {
        if (giftCardName) giftCardName.textContent = gName;
        if (giftCardTag)  giftCardTag.textContent  = gTag;
        if (giftCardNote) giftCardNote.textContent = gNote;
        if (giftCardThmb) {
          giftCardThmb.innerHTML = gImg
            ? '<img src="' + gImg + '" alt="">'
            : '<div class="lp-gwp-imgph"></div>';
        }
      }
    }
    cadBtns.forEach(function (b) {
      b.addEventListener('click', function () { setCadence(b); });
    });
    var activeCad = root.querySelector('[data-lp-cadence].is-active');
    if (activeCad) setCadence(activeCad);

    // ── Buy form: route through Shopify checkout w/ optional discount code ──
    var form = root.querySelector('[data-lp-buy-form]');
    if (form) {
      form.addEventListener('submit', function (e) {
        var discount = root.getAttribute('data-discount-code') || '';
        if (discount) {
          var sep = form.action.indexOf('?') > -1 ? '&' : '?';
          form.action = form.action.split('?')[0] +
            '?return_to=' + encodeURIComponent('/checkout?discount=' + discount);
        }
        // If no variant chosen, prevent submit
        if (cartVariant && !cartVariant.value) {
          e.preventDefault();
          var firstCad = root.querySelector('[data-lp-cadence]');
          if (firstCad) firstCad.focus();
        }
      });
    }

    // ── FAQ accordion ──
    root.querySelectorAll('[data-lp-faq-toggle]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var item = btn.closest('[data-lp-faq]');
        if (!item) return;
        var open = item.classList.toggle('is-open');
        btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      });
    });

    // ── Suppress theme-rendered footer / newsletter / "designed by ante-studio"
    //    that survives the template-level removal. CSS handles the known
    //    selectors; this JS is a fallback that catches any node containing
    //    common ante-credit text and any <footer> outside our section. ──
    function hideThemeFooterArtifacts() {
      var KNOWN_SEL = [
        '.ante-footer', '.ante-newsletter', '.ante-newsletter-bar',
        '.ante-credits', '.ante-credit', '.ante-footer-credit',
        '.ante-studio', '.ante-studio-credit',
        '[data-section-type="ante-footer"]',
        '[data-section-type="ante-newsletter"]',
        '[data-section-type="ante-credits"]'
      ].join(',');
      document.querySelectorAll(KNOWN_SEL).forEach(function (el) {
        if (!root.contains(el)) el.style.display = 'none';
      });
      // Heuristic: hide any <footer> or .site-footer that's not inside our section.
      document.querySelectorAll('footer, .site-footer, #shopify-section-footer, [id^="shopify-section-footer"]').forEach(function (el) {
        if (!root.contains(el)) el.style.display = 'none';
      });
      // Hide any element whose text contains the ante-studio credit line.
      var rx = /designed\s+by\s+ante|ante\s*studio|anti\s*studio/i;
      document.querySelectorAll('body *:not(script):not(style):not(noscript)').forEach(function (el) {
        if (root.contains(el)) return;
        if (el.children.length > 0) return; // only leaf text nodes
        if (rx.test(el.textContent || '')) {
          // Hide the smallest reasonable container (leaf + parent if it's tiny)
          el.style.display = 'none';
          if (el.parentElement && el.parentElement.children.length <= 2 && !root.contains(el.parentElement)) {
            el.parentElement.style.display = 'none';
          }
        }
      });
    }
    hideThemeFooterArtifacts();
    if (document.readyState !== 'complete') {
      window.addEventListener('load', hideThemeFooterArtifacts);
    }
  })();
</script>

