    font-size: 32px; line-height: 1; color: var(--gwp-ink); }
  .lp-reviews__rating-sub { font-family: var(--gwp-font-body); font-size: 12px;
    color: var(--gwp-gray-70); letter-spacing: 0.06em; }

  /* Reverse-direction marquee — matches press marquee pace, opposite direction */
  .lp-reviews__track-wrap { width: 100%; padding: 12px 0 28px;
    mask-image: linear-gradient(90deg, transparent 0, #000 4%, #000 96%, transparent 100%);
