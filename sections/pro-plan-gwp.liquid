  .lp-reviews__track { display: flex; gap: 24px; width: max-content;
    animation: lp-gwp-marquee-rev 60s linear infinite; }
  .lp-reviews__track-wrap:hover .lp-reviews__track,
  .lp-reviews__track:hover { animation-play-state: paused; }
  @keyframes lp-gwp-marquee-rev {
    0%   { transform: translateX(-33.333%); }
    100% { transform: translateX(0); }
  }
  .lp-review { flex: 0 0 380px;
    background: #fff; border-radius: 20px; padding: 28px 28px 24px;
    box-shadow: 0 12px 24px rgba(0,0,0,.06), 0 2px 4px rgba(0,0,0,.04);
    display: flex; flex-direction: column; }
