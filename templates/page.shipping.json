            "section_id": "",
            "header": "<strong>Holiday Shipping</strong>",
            "text": "<p>Place your order by the following dates to receive it in time for Christmas*</p><p>Standard Shipping: Order by December 13th <br/>Expedited Shipping: Order by December 19th 2 PM CT</p>",
