          "type": "section",
          "settings": {
            "section_id": "",
            "header": "<strong>Privacy Policy</strong>",
            "text": "<p>We respect your privacy and will use your information as outlined in our Privacy Policy, available at <a href=\"/pages/privacy\" title=\"Privacy Policy\">mysterytacklebox.com/pages/privacy</a>. We do not share or sell SMS opt-in data or consent status with nonaffiliated third parties for marketing purposes. Tracking mechanisms, such as cookies, may be used to monitor cart activity and send abandoned cart reminders. For more information, please review our Privacy Policy.</p>",
            "button_text": "",
