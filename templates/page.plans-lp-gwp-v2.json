        "faq_ship": {
          "type": "faq_item",
          "settings": {
            "question": "When does my free gift ship?",
            "answer": "<p>Your free gift ships with your first MTB box. Monthly and 4-month plans get an MTB Snapback Hat. 6-month and 12-month plans get the MTB Field Kit. Both ship from our warehouse in Illinois within 2–3 business days of signup.</p>"
          }
        },
        "faq_color": {
          "type": "faq_item",
          "settings": {
            "question": "Can I pick the color of my snapback or field kit?",
            "answer": "<p>We send the current-season colorway — usually MTB Green or Squid Ink. Field Kit contents and color are fixed (it's a curated kit, not a build-your-own). Fair warning: they're limited runs.</p>"
          }
        },
        "faq_cancel": {
          "type": "faq_item",
          "settings": {
            "question": "What if I cancel after I get my free gift?",
            "answer": "<p>Keep the gift, it's yours. We just ask that you stay subscribed long enough to receive your first box (so we're not running a hat-only giveaway here). After that — pause, skip, or cancel from your dashboard anytime.</p>"
          }
        },
        "faq_species": {
          "type": "faq_item",
          "settings": {
            "question": "Is the gift available on every species?",
            "answer": "<p>Yep. Bass, Multi-Species, Catfish, Inshore Saltwater, and Panfish — pick any species, any cadence, and your free gift unlocks automatically based on the plan length.</p>"
          }
        },
        "faq_gift": {
          "type": "faq_item",
          "settings": {
            "question": "I want to gift this to someone else. Will the hat fit them?",
            "answer": "<p>Our snapback is one-size-fits-most with a flexible mesh-back. Cheat code: at checkout, choose &quot;Send as a gift&quot; and we'll include a personalized note and ship straight to your recipient. The free gift goes with the first box.</p>"
          }
        },
        "faq_kit": {
          "type": "faq_item",
          "settings": {
            "question": "What's actually in the MTB Field Kit?",
            "answer": "<p>A waxed-canvas tackle wrap, MTB-branded line snips, a digital fish scale, retractable tape measure, microfiber rag, and a pack of pro stickers. Retail value runs about $68. Field-tested by our own pros — not white-labeled junk.</p>"
          }
        },
        "faq_duration": {
          "type": "faq_item",
          "settings": {
            "question": "How long is this gift-with-purchase offer running?",
            "answer": "<p>Through the end of the season, while supplies last. We made plenty, but the field kits in particular tend to run out fast around Father's Day and the holidays. Lock yours in.</p>"
          }
        }
      },
