    "ante_reviews_kc4rrb": {
      "type": "ante-reviews",
      "blocks": {
        "review_Rkbwgn": {
          "type": "review",
          "settings": {
            "star_rating": 5,
            "heading": "What a Father's Day gift",
            "review": "I received the mystery tackle box as a gift for Father’s Day, I fish every weekend and can’t wait to try the new lures out. The boxes have been better each month and I am getting more fish each month. This Saturday I tried the Bucca baby Rat and caught 3 nice small mouth bass in under 1 hour on the River.",
            "name": "Jay P",
            "image": "shopify://shop_images/cambob_69-01.jpg"
          }
        },
        "review_ehLqWb": {
          "type": "review",
          "settings": {
            "star_rating": 5,
            "heading": "The variety fuels my fishing",
            "review": "MTB keeps my arsenal growing with new lures every month. The variety fuels my fishing and my YouTube content.",
            "name": "Jay P"
          }
        },
        "review_wkFiLn": {
          "type": "review",
          "settings": {
            "star_rating": 5,
            "heading": "Stepping up to a bigger box",
            "review": "After trying another trial subscription of the $20 economy box on a 3 month plan, after the 1st box it became apparent that a step up was needed. I traded my last 2 remaining boxes for 1 elite box. I was much more happy with results.",
            "name": "Charles Hughes jr",
            "image": "shopify://shop_images/IMG_9236.jpg"
          }
        },
        "review_9Dambm": {
          "type": "review",
          "settings": {
            "star_rating": 5,
            "heading": "Best Monthly Surprise!",
            "review": "I’ve been using mystery tackle box for years now and it’s hand down the best fishing subscription on the market. The variety and quality of lures + detailed fishing tips make it something I look forward to every month. I’m constantly losing lures but my tackle box is always set up thanks to MTB!",
            "name": "Mia Wallace"
          }
        },
        "review_AnRBNm": {
          "type": "review",
          "settings": {
            "star_rating": 5,
            "heading": "All around 5 stars",
            "review": "All around 5 stars. Customer service is incredible, and I love the variety of stuff I get every month. Going to give it as a gift to dad for dads day!!",
            "name": "Julia"
          }
        },
        "review_mWRRnF": {
          "type": "review",
          "settings": {
            "star_rating": 5,
            "heading": "Our Grandson loved it",
            "review": "Our Grandson loved it! Fishing is his thing. If he's wetting a hook he's happy. He said there were lots of good things and eveything was probably worth $150!",
            "name": "Patrice Markham",
            "image": "shopify://shop_images/379705102_18002016809091443_6375290940744865677_n.jpg"
          }
        },
        "review_tyMxrT": {
          "type": "review",
          "settings": {
            "star_rating": 4,
            "heading": "Daughter loves getting the boxes",
            "review": "Daughter loves getting the boxes. She looks forward to seeing what she gets. The items are well worth the cost of the gifting subscription.",
            "name": "Benjamin Candelaria"
          }
        },
        "review_Y7GbxU": {
          "type": "review",
          "settings": {
            "star_rating": 5,
            "heading": "highly recommend",
            "review": "I highly recommend mystery tackle box. I find they send amazing lures.",
            "name": "Stephen"
          }
        }
      },
