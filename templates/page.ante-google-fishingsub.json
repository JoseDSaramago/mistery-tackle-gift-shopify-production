    "ante_faq_FxqJUe": {
      "type": "ante-faq",
      "blocks": {
        "faq_4hxUHP": {
          "type": "faq",
          "name": "subscription #1",
          "settings": {
            "category": "subscription",
            "title": "Can I cancel anytime?",
            "content": "<p>Yes. Cancel from your account dashboard anytime before the last day of the month and you won’t be billed again.</p>"
          }
        },
        "faq_fL7zHk": {
          "type": "faq",
          "name": "subscription #2",
          "settings": {
            "category": "subscription",
            "title": "Can I switch species later?",
            "content": "<p>Absolutely. Change your box type at any time in your account.</p>"
          }
        },
        "faq_GbEHyR": {
          "type": "faq",
          "name": "subscription #3",
          "settings": {
            "category": "subscription",
            "title": "Will I get duplicates?",
            "content": "<p>We work hard to keep boxes fresh with seasonal, pro-picked lures. Customers say the variety keeps them discovering new baits.</p>"
          }
        },
        "faq_mQFw4d": {
          "type": "faq",
          "name": "subscription #4",
          "settings": {
            "category": "subscription",
            "title": "What if I don’t like a lure?",
            "content": "<p>Every lure is full-sized, expert-vetted, and proven to catch fish. Even if one isn’t your favorite, anglers tell us they often discover new confidence baits.</p>"
          }
        },
        "faq_BNeezW": {
          "type": "faq",
          "name": "Delivery & Returns #1",
          "settings": {
            "category": "Delivery & Returns",
            "title": "When will my first box ship?",
            "content": "<p>Your first box is packed within 5-6 business days of your order. After that, boxes ship during the first 10 days of each month.</p>"
          }
        },
        "faq_tC8pKx": {
          "type": "faq",
          "name": "Delivery & Returns #2",
          "settings": {
            "category": "Delivery & Returns",
            "title": "How long does delivery take?",
            "content": "<p>Most boxes arrive within 5–7 business days in the US (a little longer in Canada). You’ll always get a tracking number.</p>"
          }
        },
        "faq_axYLGL": {
          "type": "faq",
          "name": "Delivery & Returns #3",
          "settings": {
            "category": "Delivery & Returns",
            "title": "Do I pay for shipping?",
            "content": "<p>Right now, shipping is free across all plans until Sept 21. After that, monthly prices include shipping so there are no surprise fees.</p>"
          }
        },
        "faq_gWhbep": {
          "type": "faq",
          "name": "Delivery & Returns #4",
          "settings": {
            "category": "Delivery & Returns",
            "title": "Can I return or exchange my box?",
            "content": "<p>All sales are final on subscription boxes. If your box is missing items or arrives damaged, our support team will replace it quickly.</p>"
          }
        },
