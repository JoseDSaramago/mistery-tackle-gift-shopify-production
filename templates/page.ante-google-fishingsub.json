        "drop_KNVKRP": {
          "type": "drop",
          "name": "Can I cancel or switch?",
          "settings": {
            "title": "Can I Cancel or switch?",
            "content": "<p>Commitment issues? We get it. Bail whenever you want with one click. Bored with bass? Switch to walleye like you're changing Netflix shows. Need a fishing detox? Hit pause and come back when the itch returns. You're the captain of this ship.</p>"
          }
        },
        "drop_RaiNg4": {
          "type": "drop",
          "name": "Is the gear legit?",
          "settings": {
            "title": "Is the gear legit?",
            "content": "<p>We skip the clearance rack entirely. Each lure is professionally selected for one purpose: putting fish in your boat, not collecting cobwebs in storage. Our customers love discovering hard-to-find baits that local shops either sell out of or never stock.</p>"
