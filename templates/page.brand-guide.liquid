  <div class="mtb-toast" id="mtb-toast" role="status" aria-live="polite"></div>

  <script>
  (function () {
    var root = document.querySelector('.mtb-bg');
    if (!root) return;

    // Background that contrasts with the chosen logo color.
    var BG_FOR_COLOR = {
      white: 'green',
      green: 'cream',
      black: 'cream',
      yellow: 'green'
    };

    // ---------- Logo swatch toggle (multi-color cards only) ----------
    root.querySelectorAll('.logo-stage').forEach(function (stage) {
      var dots = stage.querySelectorAll('.swatch-dot');
      if (dots.length === 0) return;
      var img = stage.querySelector('img');
      dots.forEach(function (dot) {
        dot.addEventListener('click', function () {
          var color = dot.getAttribute('data-color');
          var src = stage.getAttribute('data-file-' + color);
          if (src) {
            img.src = src;
            var alt = (img.getAttribute('alt') || '').split(' — ')[0];
            img.alt = alt + ' — ' + color;
          }
          stage.setAttribute('data-bg', BG_FOR_COLOR[color] || 'cream');
          stage.setAttribute('data-current', color);
          dots.forEach(function (d) { d.classList.toggle('active', d === dot); });
        });
      });
    });

    // ---------- Active section in topnav ----------
    var sectionIds = ['logos', 'color', 'type', 'doodles', 'downloads'];
    var navLinks = root.querySelectorAll('.topnav-links a');
    function setActive() {
      var current = sectionIds[0];
      sectionIds.forEach(function (id) {
        var el = document.getElementById(id);
        if (el && el.getBoundingClientRect().top < 200) current = id;
      });
      navLinks.forEach(function (a) {
        a.classList.toggle('active', a.getAttribute('href') === '#' + current);
      });
    }
    window.addEventListener('scroll', setActive, { passive: true });
    setActive();

    // ---------- Copy-to-clipboard ----------
    var toast = document.getElementById('mtb-toast');
    var toastTimer;
    function showToast(msg) {
      if (!toast) return;
      toast.textContent = msg;
      toast.classList.add('show');
      clearTimeout(toastTimer);
      toastTimer = setTimeout(function () { toast.classList.remove('show'); }, 1600);
    }
    function fallbackCopy(text) {
      var ta = document.createElement('textarea');
      ta.value = text;
      ta.style.position = 'fixed';
      ta.style.left = '-9999px';
      document.body.appendChild(ta);
      ta.select();
      try { document.execCommand('copy'); } catch (e) { /* noop */ }
      document.body.removeChild(ta);
    }
    root.querySelectorAll('.copyable').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var value = btn.getAttribute('data-copy') || '';
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(value).catch(function () { fallbackCopy(value); });
        } else {
          fallbackCopy(value);
        }
        btn.classList.add('copied');
        showToast('Copied ' + value);
        setTimeout(function () { btn.classList.remove('copied'); }, 1200);
      });
    });

  })();
  </script>
