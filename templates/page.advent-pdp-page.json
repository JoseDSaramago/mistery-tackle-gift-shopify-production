    "ante_faq_bbGdh4": {
      "type": "ante-faq",
      "blocks": {
        "faq_9MxfPN": {
          "type": "faq",
          "name": "subscription #1",
          "settings": {
            "category": "fishmas info",
            "title": "What’s inside the Advent Calendar?",
            "content": "<p>Each calendar includes 10 premium fishing pieces of tackle (like hard baits, soft plastics, and hooks), 1 exclusive Fishmas decal, and 1 surprise mystery gift from our friends at MeatEater. Every slot reveals something new to help anglers catch more fish and spread holiday cheer. It also includes access to digital content with tips & tricks about how to fish everything in your box.</p>"
          }
        },
        "faq_6qbzUh": {
          "type": "faq",
          "name": "subscription #2",
          "settings": {
            "category": "fishmas info",
            "title": "What fishing brands are included?",
            "content": "<p>We partner with the best brands in fishing like Xcite Baits, Lunkerhunt, Googan Squad, and Luck E Strike to deliver quality products guaranteed to catch more fish.</p>"
          }
        },
        "faq_ey66Va": {
          "type": "faq",
          "name": "subscription #3",
          "settings": {
            "category": "fishmas info",
            "title": "Is this for kids, adults, or both?",
            "content": "<p>Both! The Fishmas Calendar makes the perfect fishing gift for anglers of any age or skill level. Whether you’re shopping for a young beginner or a seasoned pro, the curated mix of tackle guarantees fun and fish-catching potential.</p>"
          }
        },
        "faq_MWAqz4": {
          "type": "faq",
          "name": "subscription #4",
          "settings": {
            "category": "fishmas info",
            "title": "How big is the calendar?",
            "content": "<p>Bigger is better when it comes to fishing—and advent calendars! This box is 18.5” wide x 16.5” tall, making it a statement gift that looks great under the tree (or next to the tackle box).</p>"
          }
        },
        "faq_9j6tt9": {
          "type": "faq",
          "name": "Delivery & Returns #1",
          "settings": {
            "category": "Delivery & Returns",
            "title": "When will I get my Advent Calendar?",
            "content": "<p>Customers in the continental US, please allow up to 7 business days from the time the order ships for delivery. Final delivery will be made by the United States Postal Service (USPS). Customers in Canada, please allow up to 2-3 weeks for delivery.</p>"
          }
        },
        "faq_PdQMNG": {
          "type": "faq",
          "name": "Delivery & Returns #2",
          "settings": {
            "category": "Delivery & Returns",
            "title": "If I want this by Christmas, when should I order?",
            "content": "<p>If you want to receive your order on the official start of the 12 Days of Fishmas, order by 12/3/25. If you want to receive your order by Christmas, order by 12/15/25.</p>"
          }
        },
        "faq_3xdT9j": {
          "type": "faq",
          "name": "Delivery & Returns #3",
          "settings": {
            "category": "Delivery & Returns",
            "title": "How do I track my order?",
            "content": "<p>You will receive an email with your tracking number when the order ships. If you did not receive this email, we recommend checking your spam & promotions folders. If you are still unable to locate the tracking email, please reach out to our team at support@mysterytacklebox.com, and we'll be happy to help!</p>"
          }
        },
        "faq_FQTPGn": {
          "type": "faq",
          "name": "Delivery & Returns #4",
          "settings": {
            "category": "Delivery & Returns",
            "title": "What happens if I am missing something in my box?",
            "content": "<p>If you are missing anything from your box, please contact our support team at support@mysterytacklebox.com. Our friendly staff will always ensure you receive the correct products or box.</p>"
          }
        },
