fetch("/cart.js")
  .then(r => r.json())
  .then(async cart => {
    for (let i = cart.items.length - 1; i >= 0; i--) {
      const item = cart.items[i]
      const data = item.properties?._data

      if (typeof data === "string" && data.startsWith("f:")) {
        await fetch("/cart/change.js", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            id: item.key,
            quantity: 0
          })
        })
      }
    }
  })

